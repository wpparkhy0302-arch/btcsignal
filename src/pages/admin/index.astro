---
import { createHmac } from 'crypto';

const adminPassword = import.meta.env.ADMIN_PASSWORD ?? '';
const sessionCookie = Astro.cookies.get('admin_session')?.value ?? '';

let isAuthenticated = false;
if (adminPassword && sessionCookie) {
  const expected = createHmac('sha256', adminPassword).update('admin-session').digest('hex');
  isAuthenticated = sessionCookie === expected;
}

if (!isAuthenticated) {
  return Astro.redirect('/admin/login');
}
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>BTC Signal AI - Admin</title>
  <style is:global>
    :root{
      --bg:#050914;
      --card:#101827;
      --card2:#121d32;
      --border:#1f2b45;
      --border2:#24406b;
      --text:#f8fafc;
      --text2:#94a3b8;
      --text3:#64748b;
      --green:#10b981;
      --blue:#3b82f6;
      --red:#ff4d5a;
      --yellow:#ffb020;
    }
    *{box-sizing:border-box}
    body{
      margin:0;
      background:linear-gradient(180deg,#040814 0%,#050914 100%);
      color:var(--text);
      font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;
    }
    .wrap{max-width:1000px;margin:0 auto;padding:28px 20px 46px}
    .topbar{
      display:flex;justify-content:space-between;align-items:flex-start;
      margin-bottom:24px;border-bottom:1px solid var(--border);padding-bottom:18px
    }
    .brand{display:flex;gap:14px;align-items:flex-start}
    .logo{
      width:34px;height:34px;border-radius:9px;background:var(--green);
      display:grid;place-items:center;font-weight:800;color:#fff
    }
    .title{font-size:18px;font-weight:800;line-height:1.2}
    .sub{font-size:13px;color:var(--text2);margin-top:4px}
    .topbar-right{display:flex;align-items:center;gap:10px}
    .admin-badge{
      padding:6px 12px;border-radius:999px;border:1px solid #6b4b10;
      color:#ffb020;background:rgba(255,176,32,.08);font-size:12px;font-weight:700
    }
    .btn-logout{
      padding:6px 14px;border-radius:999px;border:1px solid var(--border2);
      color:var(--text2);background:transparent;font-size:12px;font-weight:700;cursor:pointer;
      transition:border-color .2s,color .2s;
    }
    .btn-logout:hover{border-color:#ff4d5a;color:#ff9aa3}
    .panel{
      background:linear-gradient(180deg,#111a2c,#0f1728);
      border:1px solid var(--border);
      border-radius:14px;padding:22px;margin-bottom:20px
    }
    .panel-title{
      font-size:14px;font-weight:800;margin-bottom:14px;display:flex;align-items:center;gap:8px
    }
    .panel-title .dot{width:9px;height:9px;border-radius:50%;background:var(--green)}
    .stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-top:12px;margin-bottom:20px}
    .stat-card{
      background:rgba(255,255,255,.02);
      border:1px solid var(--border);
      border-radius:12px;padding:18px
    }
    .stat-lbl{font-size:12px;color:var(--text2);margin-bottom:8px}
    .stat-val{font-size:26px;font-weight:800}
    .blue{color:var(--blue)} .green{color:var(--green)} .red{color:var(--red)} .yellow{color:var(--yellow)}
    .sec-label{font-size:13px;font-weight:800;color:var(--text2);margin:22px 0 12px}
    .row-2{display:grid;grid-template-columns:1fr 1fr auto;gap:10px;align-items:end}
    .gen-card{
      background:linear-gradient(180deg,#111a2c,#0f1728);
      border:1px solid var(--border);
      border-radius:14px;padding:20px
    }
    .gen-row{display:grid;grid-template-columns:1.3fr 1.2fr auto;gap:10px}
    .field{display:flex;flex-direction:column;gap:8px}
    .field label{font-size:12px;color:var(--text2);font-weight:700}
    input,select{
      width:100%;height:42px;border-radius:10px;border:1px solid var(--border2);
      background:#0a1020;color:var(--text);padding:0 14px;font-size:15px;outline:none
    }
    input::placeholder{color:#5e6d86}
    .btn-save,.btn-gen,.btn-copy,.btn-export,.btn-revoke,.btn-add{
      height:42px;border:none;border-radius:10px;font-weight:800;font-size:14px;cursor:pointer
    }
    .btn-save,.btn-gen{background:var(--green);color:#fff;padding:0 22px}
    .btn-copy{
      background:#17305a;color:#60a5fa;border:1px solid #28508d;padding:0 22px
    }
    .btn-export{
      background:#091a34;color:#4ea0ff;border:1px solid #0f4ea6;padding:0 16px
    }
    .btn-add{
      background:#0f3a2c;color:#7ef0b9;border:1px solid #1d7f5a;padding:0 18px
    }
    .btn-revoke{
      background:transparent;border:1px solid var(--border2);color:#cbd5e1;padding:0 10px;height:34px
    }
    .btn-revoke.revoked{color:#ff8d96;border-color:#7d2d36}
    .btn-revoke.active{color:#7ef0b9;border-color:#206d55}
    .sub-card{
      background:linear-gradient(180deg,#111a2c,#0f1728);
      border:1px solid var(--border);
      border-radius:14px;
      overflow:hidden;
      margin-bottom:20px;
    }
    .sub-card-search{
      display:grid;grid-template-columns:1fr auto;gap:10px;align-items:center;
      padding:16px 20px;border-bottom:1px solid var(--border)
    }
    .sub-card-search .search-input{height:40px}
    .sub-card .table-wrap{
      border:none;border-radius:0;background:transparent;margin-bottom:0
    }
    .search-row{
      display:grid;grid-template-columns:1fr auto;gap:10px;align-items:center;margin-bottom:10px
    }
    .search-input{height:40px}
    .table-wrap{
      overflow:hidden;border:1px solid var(--border);border-radius:12px;background:rgba(255,255,255,.02)
    }
    .lic-table{width:100%;border-collapse:collapse;table-layout:fixed}
    .lic-table th{
      padding:12px 16px;border-bottom:1px solid var(--border);
      font-size:12px;color:var(--text2);font-weight:800;text-align:left;
      white-space:nowrap;overflow:hidden;text-overflow:ellipsis
    }
    .lic-table td{
      padding:12px 16px;border-bottom:1px solid rgba(255,255,255,.04);
      font-size:14px;vertical-align:middle;
      overflow:hidden;text-overflow:ellipsis;white-space:nowrap
    }
    .lic-table tr:last-child td{border-bottom:none}
    .lic-table tr.revoked-row td{opacity:.72}
    .lic-table th:nth-child(1){width:26%}
    .lic-table th:nth-child(2){width:12%}
    .lic-table th:nth-child(3){width:10%}
    .lic-table th:nth-child(4){width:10%}
    .lic-table th:nth-child(5){width:11%}
    .lic-table th:nth-child(6){width:9%}
    .lic-table th:nth-child(7){width:22%}
    .mono{
      font-family:ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;
      font-size:13px
    }
    .status-badge{
      display:inline-flex;align-items:center;justify-content:center;
      min-width:54px;height:28px;border-radius:999px;font-size:12px;font-weight:800
    }
    .status-badge.active{background:rgba(16,185,129,.12);color:#6ee7b7;border:1px solid rgba(16,185,129,.3)}
    .status-badge.revoked{background:rgba(255,77,90,.10);color:#ff9aa3;border:1px solid rgba(255,77,90,.25)}
    .status-badge.expired{background:rgba(255,176,32,.10);color:#ffd37a;border:1px solid rgba(255,176,32,.25)}
    .empty-state{padding:46px 20px;text-align:center;color:var(--text3)}
    .gen-result{
      display:none;margin-top:14px;padding:14px;border-radius:12px;
      border:1px solid #1e6d53;background:rgba(16,185,129,.08);
      align-items:center;justify-content:space-between;gap:12px
    }
    .gen-result.show{display:flex}
    .gen-key-val{
      font-family:ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;
      font-size:18px;font-weight:800;color:#8af6c4;word-break:break-all
    }
    .gen-key-meta{margin-top:6px;color:#9fb4c7;font-size:13px}
    .toast{
      position:fixed;left:50%;bottom:26px;transform:translateX(-50%) translateY(20px);
      min-width:220px;max-width:90vw;padding:14px 18px;border-radius:12px;
      background:#0b1325;border:1px solid var(--border2);color:#fff;
      opacity:0;pointer-events:none;transition:all .25s ease;z-index:9999;
      box-shadow:0 18px 40px rgba(0,0,0,.35);text-align:center;font-weight:700
    }
    .toast.show{opacity:1;transform:translateX(-50%) translateY(0)}
    .toast.green{border-color:#1c7f5b}
    .toast.red{border-color:#7d2d36}
    .helper{font-size:12px;color:var(--text2);margin-top:8px}
    @media (max-width: 900px){
      .stats-grid{grid-template-columns:1fr 1fr}
      .gen-row,.row-2,.search-row,.sub-card-search{grid-template-columns:1fr}
      .lic-table thead{display:none}
      .lic-table td{display:block;text-align:right;padding:8px 16px}
      .lic-table td::before{content:attr(data-label);float:left;font-size:11px;color:var(--text3);font-weight:700}
      .proof-grid-head{display:none}
      .proof-grid-row{grid-template-columns:1fr;gap:8px;padding:16px}
      .gen-result.show{display:block}
      .btn-add{margin-top:12px;width:100%}
    }
    .proof-panel{margin-top:22px}
    .proof-toolbar{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:12px}
    .proof-grid-head,.proof-grid-row{
      display:grid;
      grid-template-columns:1.2fr .9fr .9fr .8fr .55fr .65fr;
      gap:8px;align-items:center
    }
    .proof-grid-head{
      font-size:12px;color:var(--text2);font-weight:800;
      padding:0 11px 10px
    }
    .proof-grid-row{
      background:rgba(255,255,255,.02);
      border:1px solid var(--border);
      border-radius:12px;
      padding:10px;
      margin-bottom:8px
    }
    .proof-small-input,.proof-small-select{
      width:100%;height:38px;border-radius:9px;border:1px solid var(--border2);
      background:#0a1020;color:var(--text);padding:0 10px;font-size:14px;outline:none
    }
    .proof-check{display:flex;align-items:center;justify-content:center}
    .proof-check input{width:18px;height:18px}
    .proof-remove{
      height:38px;border-radius:9px;border:1px solid #7d2d36;background:transparent;color:#ff9aa3;
      font-weight:800;cursor:pointer
    }
    .proof-phrase-wrap{margin-top:14px}
    .proof-phrase-textarea{
      width:100%;min-height:110px;border-radius:12px;border:1px solid var(--border2);
      background:#0a1020;color:var(--text);padding:12px 14px;font-size:14px;outline:none;resize:vertical
    }
  </style>
</head>
<body>
  <div class="wrap">
    <div class="topbar">
      <div class="brand">
        <div class="logo">₿</div>
        <div>
          <div class="title">BTC Signal AI — Admin</div>
          <div class="sub">License key management &amp; subscribers</div>
        </div>
      </div>
      <div class="topbar-right">
        <div class="admin-badge">ADMIN</div>
        <a href="/api/admin/logout"><button class="btn-logout">Log out</button></a>
      </div>
    </div>

    <div class="panel">
      <div class="panel-title"><span class="dot"></span> Landing Page Stats</div>
      <div class="row-2">
        <div class="field">
          <label>Total Buyers</label>
          <input id="buyersInput" type="number" placeholder="e.g. 127">
        </div>
        <div class="field">
          <label>Re-subscription Rate (%)</label>
          <input id="resubInput" type="number" placeholder="e.g. 96">
        </div>
        <button class="btn-save" onclick="saveLandingStats()">Save</button>
      </div>
      <div class="helper" id="statsMsg">Enter numbers to update landing stats.</div>
    </div>

    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-lbl">Total Keys</div>
        <div class="stat-val blue" id="statTotal">0</div>
      </div>
      <div class="stat-card">
        <div class="stat-lbl">Active</div>
        <div class="stat-val green" id="statActive">0</div>
      </div>
      <div class="stat-card">
        <div class="stat-lbl">Cancelled / Suspended</div>
        <div class="stat-val red" id="statRevoked">0</div>
      </div>
      <div class="stat-card">
        <div class="stat-lbl">Expiring (30d)</div>
        <div class="stat-val yellow" id="statSoon">0</div>
      </div>
    </div>

    <div class="sec-label">Issue New License Key</div>
    <div class="gen-card">
      <div class="gen-row">
        <div class="field">
          <label>Buyer Name</label>
          <input type="text" id="genName" placeholder="e.g. John Doe">
        </div>
        <div class="field">
          <label>Subscription Period</label>
          <select id="genPeriod">
            <option value="1">1 Month</option>
            <option value="3">3 Months</option>
            <option value="6">6 Months</option>
            <option value="12" selected>12 Months</option>
            <option value="24">24 Months (2yr)</option>
            <option value="120">Lifetime</option>
          </select>
        </div>
        <div class="field">
          <label>Max Devices</label>
          <select id="genMaxDev">
            <option value="1">1 Device</option>
            <option value="2">2 Devices</option>
            <option value="3">3 Devices</option>
            <option value="99">Unlimited</option>
          </select>
        </div>
      </div>
      <div class="gen-row" style="margin-top:10px;grid-template-columns:auto auto;">
        <button class="btn-gen" id="btnGen" onclick="generateKey()">Issue Key</button>
        <button class="btn-copy" onclick="copyLastKey()">Copy</button>
      </div>
      <div class="gen-result" id="genResult">
        <div>
          <div class="gen-key-val" id="genKeyVal"></div>
          <div class="gen-key-meta" id="genKeyMeta"></div>
        </div>
        <button class="btn-add" onclick="refreshTable()">Refresh List</button>
      </div>
    </div>

    <div class="sec-label">Live Purchase Activity</div>
    <div class="panel proof-panel">
      <div class="panel-title"><span class="dot"></span> Landing Page Buyer List</div>
      <div class="helper">Edit the live purchase list and popup phrases displayed on the landing page.</div>
      <div class="proof-toolbar" style="margin-top:14px">
        <button class="btn-save" type="button" onclick="addProofRow()">Add Row</button>
        <button class="btn-copy" type="button" onclick="saveProofData()">Save List</button>
      </div>
      <div class="proof-grid-head">
        <span>Masked Name</span>
        <span>Plan</span>
        <span>Price</span>
        <span>Color</span>
        <span>Visible</span>
        <span></span>
      </div>
      <div id="proofRows"></div>
      <div class="proof-phrase-wrap">
        <label style="display:block;font-size:12px;color:var(--text2);font-weight:700;margin-bottom:8px">Toast Phrases (one per line)</label>
        <textarea id="toastPhrases" class="proof-phrase-textarea" placeholder="just joined&#10;just purchased&#10;recently subscribed"></textarea>
        <div class="helper">These phrases rotate in the small popup notifications.</div>
      </div>
    </div>

    <div class="sec-label">Subscribers</div>
    <div class="sub-card">
      <div class="sub-card-search">
        <input class="search-input" id="searchInput" placeholder="Search by name or key..." oninput="renderTable()">
        <button class="btn-export" onclick="exportCSV()">Export CSV</button>
      </div>
      <div class="table-wrap">
        <table class="lic-table">
          <thead>
            <tr>
              <th>License Key</th>
              <th>Customer</th>
              <th>Issued</th>
              <th>Expires</th>
              <th>Last Used</th>
              <th>Status</th>
              <th></th>
            </tr>
          </thead>
          <tbody id="tableBody">
            <tr><td colspan="7" class="empty-state">No keys issued yet. Issue a new key above.</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <div class="toast" id="toast"></div>

  <script is:inline define:vars={{ adminPassword }}>
    const WP_API = 'https://wordpress-1588000-6280934.cloudwaysapps.com/wp-json/btcai/v1';
    const ADMIN_TOKEN = adminPassword;

    function escapeHtml(value) {
      return String(value)
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;');
    }

    function defaultProofItems() {
      return [
        { name:'ko***27', plan:'3개월', price:'79,000원', color:'green', enabled:true },
        { name:'bit***91', plan:'12개월', price:'249,000원', color:'blue', enabled:true },
        { name:'trd***55', plan:'1개월', price:'29,900원', color:'green', enabled:true },
        { name:'moon***k', plan:'3개월', price:'79,000원', color:'green', enabled:true },
        { name:'jin***42', plan:'12개월', price:'249,000원', color:'blue', enabled:true },
        { name:'won***78', plan:'1개월', price:'29,900원', color:'green', enabled:true },
        { name:'sol***33', plan:'3개월', price:'79,000원', color:'green', enabled:true }
      ];
    }

    function proofRowTemplate(item = {}) {
      const row = document.createElement('div');
      row.className = 'proof-grid-row';
      row.innerHTML = `
        <input class="proof-small-input proof-name" placeholder="e.g. ko***27" value="${escapeHtml(item.name || '')}">
        <select class="proof-small-select proof-plan">
          <option value="1개월" ${item.plan === '1개월' ? 'selected' : ''}>1개월</option>
          <option value="3개월" ${item.plan === '3개월' ? 'selected' : ''}>3개월</option>
          <option value="6개월" ${item.plan === '6개월' ? 'selected' : ''}>6개월</option>
          <option value="12개월" ${item.plan === '12개월' ? 'selected' : ''}>12개월</option>
          <option value="24개월 (2년)" ${item.plan === '24개월 (2년)' ? 'selected' : ''}>24개월 (2년)</option>
        </select>
        <input class="proof-small-input proof-price" placeholder="e.g. $29.00" value="${escapeHtml(item.price || '')}">
        <select class="proof-small-select proof-color">
          <option value="green" ${item.color === 'green' ? 'selected' : ''}>Green</option>
          <option value="blue" ${item.color === 'blue' ? 'selected' : ''}>Blue</option>
        </select>
        <label class="proof-check"><input type="checkbox" class="proof-enabled" ${item.enabled !== false ? 'checked' : ''}></label>
        <button type="button" class="proof-remove">Remove</button>
      `;
      row.querySelector('.proof-remove').addEventListener('click', () => row.remove());
      return row;
    }

    function addProofRow(item = {}) {
      document.getElementById('proofRows').appendChild(proofRowTemplate(item));
    }

    function collectProofRows() {
      return Array.from(document.querySelectorAll('#proofRows .proof-grid-row')).map(row => ({
        name: row.querySelector('.proof-name').value.trim(),
        plan: row.querySelector('.proof-plan').value.trim(),
        price: row.querySelector('.proof-price').value.trim(),
        color: row.querySelector('.proof-color').value.trim() || 'green',
        enabled: row.querySelector('.proof-enabled').checked
      })).filter(item => item.name && item.plan && item.price);
    }

    async function loadProofData() {
      try {
        const res = await fetch(WP_API + '/proof-data?_=' + Date.now(), {
          headers: { 'Accept': 'application/json' },
          cache: 'no-store'
        });
        const data = await res.json();
        const items = Array.isArray(data.items) && data.items.length ? data.items : defaultProofItems();
        const phrases = Array.isArray(data.toast_phrases) && data.toast_phrases.length
          ? data.toast_phrases
          : ['just joined', 'just purchased', 'recently subscribed', 'just started'];
        const box = document.getElementById('proofRows');
        box.innerHTML = '';
        items.forEach(item => addProofRow(item));
        document.getElementById('toastPhrases').value = phrases.join('\n');
      } catch (e) {
        document.getElementById('proofRows').innerHTML = '';
        defaultProofItems().forEach(item => addProofRow(item));
        document.getElementById('toastPhrases').value = ['just joined', 'just purchased', 'recently subscribed', 'just started'].join('\n');
      }
    }

    async function saveProofData() {
      const items = collectProofRows();
      const toast_phrases = document.getElementById('toastPhrases').value
        .split('\n').map(v => v.trim()).filter(Boolean);
      if (!items.length) { showToast('Please add at least one item.', 'red'); return; }
      try {
        const res = await fetch(WP_API + '/proof-data/update', {
          method: 'POST', headers: hdrs(),
          body: JSON.stringify({ items, toast_phrases })
        });
        const data = await res.json();
        if (data.ok || data.success) showToast('Purchase list saved.', 'green');
        else showToast(data.msg || 'Save failed', 'red');
      } catch (e) { showToast('Server connection error', 'red'); }
    }

    let allKeys = [];

    function hdrs() {
      return { 'Content-Type': 'application/json', 'X-Admin-Token': ADMIN_TOKEN };
    }

    function showToast(msg, type='green') {
      const el = document.getElementById('toast');
      el.textContent = msg;
      el.className = 'toast ' + type + ' show';
      clearTimeout(showToast._t);
      showToast._t = setTimeout(() => { el.className = 'toast'; }, 2200);
    }

    function fmtDate(value) {
      if (!value) return '-';
      const d = new Date(value);
      return Number.isNaN(d.getTime()) ? '-' : d.toLocaleDateString('en-US');
    }

    async function loadLandingStats() {
      try {
        const res = await fetch(WP_API + '/stats');
        const data = await res.json();
        document.getElementById('buyersInput').value = data.buyers ?? '';
        document.getElementById('resubInput').value = data.resub_rate ?? '';
      } catch (e) {
        document.getElementById('statsMsg').textContent = 'Failed to load stats';
      }
    }

    async function saveLandingStats() {
      const buyers = parseInt(document.getElementById('buyersInput').value || '0', 10);
      const resub_rate = parseInt(document.getElementById('resubInput').value || '0', 10);
      try {
        const res = await fetch(WP_API + '/stats/update', {
          method: 'POST', headers: hdrs(),
          body: JSON.stringify({ buyers, resub_rate })
        });
        const data = await res.json();
        if (data.ok || data.success) {
          document.getElementById('statsMsg').textContent = 'Saved.';
          showToast('Stats saved', 'green');
        } else {
          document.getElementById('statsMsg').textContent = data.msg || 'Save failed';
          showToast(data.msg || 'Save failed', 'red');
        }
      } catch (e) {
        document.getElementById('statsMsg').textContent = 'Save failed';
        showToast('Server error', 'red');
      }
    }

    async function loadKeys() {
      try {
        const res = await fetch('/api/admin/license/list', {
          headers: { ...hdrs(), 'Cache-Control': 'no-cache' },
          cache: 'no-store'
        });
        if (res.status === 401 || res.status === 403) { showToast('Invalid password', 'red'); return []; }
        const data = await res.json();
        if (Array.isArray(data)) return data;
        if (data && Array.isArray(data.keys)) return data.keys;
        return [];
      } catch (e) { showToast('Failed to load list', 'red'); return []; }
    }

    async function generateKey() {
      const name = document.getElementById('genName').value.trim();
      if (!name) { showToast('Enter buyer name', 'red'); return; }
      const months = parseInt(document.getElementById('genPeriod').value, 10);
      const maxDevices = parseInt(document.getElementById('genMaxDev').value, 10);
      const btn = document.getElementById('btnGen');
      btn.disabled = true; btn.textContent = 'Issuing...';
      try {
        const res = await fetch('/api/admin/license/issue', {
          method: 'POST', headers: hdrs(),
          body: JSON.stringify({ name, months, max_devices: maxDevices })
        });
        const data = await res.json();
        if (data.ok) {
          document.getElementById('genKeyVal').textContent = data.key || '';
          const label = months >= 120 ? 'Lifetime' : months + ' mo';
          document.getElementById('genKeyMeta').textContent =
            `${name} · ${label} · max ${maxDevices} device(s) · Expires: ${data.expires || fmtDate(data.expires_at)}`;
          document.getElementById('genResult').classList.add('show');
          navigator.clipboard.writeText(data.key || '').catch(() => {});
          showToast('Issued! Copied to clipboard.', 'green');
          await refreshTable();
        } else { showToast(data.msg || 'Issue failed', 'red'); }
      } catch (e) { showToast('Server error', 'red'); }
      finally { btn.disabled = false; btn.textContent = 'Issue Key'; }
    }

    function copyLastKey() {
      const key = document.getElementById('genKeyVal').textContent.trim();
      if (!key) { showToast('Issue a key first.', 'red'); return; }
      navigator.clipboard.writeText(key)
        .then(() => showToast('Copied!', 'green'))
        .catch(() => showToast('Copy failed', 'red'));
    }

    async function toggleRevoke(id, currentStatus) {
      const newStatus = currentStatus === 'active' ? 'suspended' : 'active';
      try {
        const res = await fetch('/api/admin/license/update', {
          method: 'POST', headers: hdrs(),
          body: JSON.stringify({ id, status: newStatus })
        });
        const data = await res.json();
        if (data.ok) {
          showToast(newStatus === 'suspended' ? 'Suspended.' : 'Restored.', newStatus === 'suspended' ? 'red' : 'green');
          await refreshTable();
        } else { showToast(data.msg || 'Action failed', 'red'); }
      } catch (e) { showToast('Server error', 'red'); }
    }

    async function deleteKey(id, name) {
      if (!confirm('Delete key for: ' + name + '?')) return;
      try {
        const res = await fetch('/api/admin/license/delete', {
          method: 'POST', headers: hdrs(),
          body: JSON.stringify({ id })
        });
        const data = await res.json();
        if (data.ok) { showToast('Deleted.', 'green'); await refreshTable(); }
        else { showToast(data.msg || 'Delete failed', 'red'); }
      } catch (e) { showToast('Server error', 'red'); }
    }

    async function refreshTable() {
      allKeys = await loadKeys();
      renderKeyStats(allKeys);
      renderTable();
    }

    function renderKeyStats(keys) {
      const now = new Date();
      document.getElementById('statTotal').textContent = keys.length;
      document.getElementById('statActive').textContent = keys.filter(k => {
        if (k.status !== 'active') return false;
        const exp = new Date(k.expires_at);
        return Number.isNaN(exp.getTime()) ? true : exp >= now;
      }).length;
      document.getElementById('statRevoked').textContent = keys.filter(k => k.status === 'revoked').length;
      document.getElementById('statSoon').textContent = keys.filter(k => {
        if (k.status !== 'active') return false;
        const d = (new Date(k.expires_at) - now) / 86400000;
        return d <= 30 && d > 0;
      }).length;
    }

    function renderTable() {
      const q = (document.getElementById('searchInput').value || '').toLowerCase();
      const list = allKeys.filter(k =>
        String(k.buyer_name || '').toLowerCase().includes(q) ||
        String(k.license_key || '').toLowerCase().includes(q)
      );
      const body = document.getElementById('tableBody');
      if (!list.length) {
        body.innerHTML = '<tr><td colspan="7" class="empty-state">No keys issued yet. Issue a new key above.</td></tr>';
        return;
      }
      body.innerHTML = list.map(k => {
        const st = k.status || 'active';
        const isSuspended = st === 'suspended' || st === 'revoked';
        const expTs = new Date(k.expires_at).getTime();
        const isExpired = !Number.isNaN(expTs) && expTs < Date.now() && st === 'active';
        const statusClass = isExpired ? 'expired' : (isSuspended ? 'revoked' : 'active');
        const statusLabel = isExpired ? 'Expired' : (isSuspended ? 'Suspended' : 'Active');
        const safeId = String(k.id).replace(/[^a-zA-Z0-9\-]/g, '');
        const months = Number(k.months);
        return `
          <tr class="${isSuspended ? 'revoked-row' : ''}">
            <td class="mono" data-label="License Key">${k.license_key || '-'}</td>
            <td data-label="Customer">${k.buyer_name || '-'}</td>
            <td data-label="Issued" style="color:var(--text2);font-size:12px">${fmtDate(k.issued_at)}</td>
            <td data-label="Expires" style="font-size:12px">${months >= 120 ? 'Lifetime' : fmtDate(k.expires_at)}</td>
            <td data-label="Last Used" style="font-size:12px;color:var(--text2)">${fmtDate(k.last_used)}</td>
            <td data-label="Status"><span class="status-badge ${statusClass}">${statusLabel}</span></td>
            <td data-label="Actions" style="white-space:nowrap">
              <button class="btn-revoke ${isSuspended ? 'revoked' : 'active'}" onclick="toggleRevoke('${safeId}', '${st}')">${isSuspended ? 'Restore' : 'Suspend'}</button>
              <button class="btn-revoke active" style="color:var(--text3);border-color:var(--border2);margin-left:4px" onclick="deleteKey('${safeId}', '${String(k.license_key || '').replace(/'/g, "\\'")}')">Delete</button>
            </td>
          </tr>
        `;
      }).join('');
    }

    function exportCSV() {
      if (!allKeys.length) { showToast('No data to export.', 'red'); return; }
      const rows = [['license_key','buyer_name','months','issued_at','expires_at','last_used','status','device_count','max_devices']];
      allKeys.forEach(k => rows.push([
        k.license_key||'', k.buyer_name||'', k.months||'', k.issued_at||'',
        k.expires_at||'', k.last_used||'', k.status||'', k.device_count||0, k.max_devices||0
      ]));
      const csv = rows.map(row => row.map(v => `"${String(v).replace(/"/g,'""')}"`).join(',')).join('\n');
      const blob = new Blob(['﻿' + csv], { type: 'text/csv;charset=utf-8;' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url; a.download = 'btcai-licenses.csv';
      document.body.appendChild(a); a.click(); a.remove();
      URL.revokeObjectURL(url);
    }

    (async function init() {
      await loadLandingStats();
      await loadProofData();
      await refreshTable();
    })();
  </script>
</body>
</html>
