---
import { createHmac } from 'crypto';

const adminPassword = import.meta.env.ADMIN_PASSWORD ?? '';
const sessionCookie = Astro.cookies.get('admin_session')?.value ?? '';

if (adminPassword && sessionCookie) {
  const expected = createHmac('sha256', adminPassword).update('admin-session').digest('hex');
  if (sessionCookie === expected) {
    return Astro.redirect('/admin');
  }
}

const hasError = Astro.url.searchParams.get('error') === '1';
---
<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>BTC Signal AI — 관리자 로그인</title>
  <style>
    *{box-sizing:border-box;margin:0;padding:0}
    body{
      min-height:100vh;display:flex;align-items:center;justify-content:center;
      background:linear-gradient(180deg,#040814 0%,#050914 100%);
      font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;
      color:#f8fafc;
    }
    .card{
      width:100%;max-width:380px;padding:40px 36px;
      background:linear-gradient(180deg,#111a2c,#0f1728);
      border:1px solid #1f2b45;border-radius:18px;
    }
    .logo-row{display:flex;align-items:center;gap:12px;margin-bottom:28px}
    .logo{
      width:38px;height:38px;border-radius:10px;background:#10b981;
      display:grid;place-items:center;font-weight:800;color:#fff;font-size:18px;flex-shrink:0
    }
    .logo-text{font-size:16px;font-weight:800;line-height:1.3}
    .logo-sub{font-size:12px;color:#94a3b8;margin-top:2px}
    label{display:block;font-size:12px;font-weight:700;color:#94a3b8;margin-bottom:8px}
    input[type=password]{
      width:100%;height:46px;border-radius:11px;border:1px solid #24406b;
      background:#0a1020;color:#f8fafc;padding:0 16px;font-size:15px;outline:none;
      transition:border-color .2s;
    }
    input[type=password]:focus{border-color:#3b82f6}
    .btn{
      width:100%;height:46px;margin-top:18px;border:none;border-radius:11px;
      background:#10b981;color:#fff;font-size:15px;font-weight:800;cursor:pointer;
      transition:opacity .2s;
    }
    .btn:hover{opacity:.88}
    .error{
      margin-top:14px;padding:12px 14px;border-radius:10px;
      background:rgba(255,77,90,.1);border:1px solid rgba(255,77,90,.3);
      color:#ff9aa3;font-size:13px;font-weight:700;text-align:center;
    }
    .badge{
      display:block;margin-top:20px;text-align:center;
      font-size:11px;color:#4a5568;
    }
  </style>
</head>
<body>
  <div class="card">
    <div class="logo-row">
      <div class="logo">₿</div>
      <div>
        <div class="logo-text">BTC Signal AI</div>
        <div class="logo-sub">관리자 전용 페이지</div>
      </div>
    </div>

    <form method="POST" action="/api/admin/login">
      <label for="pw">비밀번호</label>
      <input id="pw" type="password" name="password" placeholder="관리자 비밀번호 입력" autofocus required />
      <button class="btn" type="submit">로그인</button>
    </form>

    {hasError && (
      <div class="error">비밀번호가 올바르지 않습니다.</div>
    )}

    <span class="badge">ADMIN ACCESS ONLY</span>
  </div>
</body>
</html>
