<script is:inline>
const WP_API = 'https://wordpress-1588000-6280934.cloudwaysapps.com/wp-json/btcai/v1';

let proofItems = [];
let toastPhrases = ['just joined', 'purchased a moment ago', 'recently registered', 'just got started'];

function openPayment(amount, plan) {
  window.location.href = `/api/payment/create?amount=${amount}&plan=${plan}`;
}

async function loadStats() {
  try {
    const r = await fetch('/api/stats');
    if (!r.ok) return;
    const d = await r.json();
    if (d.buyers) document.getElementById('cnt1').textContent = d.buyers;
    if (d.renewal_rate) document.getElementById('cnt2').textContent = d.renewal_rate;
  } catch(e) {}
}

const PLAN_MAP = {
  '1개월': '1 month',
  '3개월': '3 months',
  '6개월': '6 months',
  '12개월': '12 months',
  '24개월 (2년)': '24 months (2yr)',
};
function mapPlan(plan) { return PLAN_MAP[plan] || plan; }

async function loadProofData() {
  try {
    const res = await fetch(WP_API + '/proof-data?_=' + Date.now(), {
      headers: { 'Accept': 'application/json' },
      cache: 'no-store'
    });
    const data = await res.json();
    if (Array.isArray(data.items) && data.items.length) {
      proofItems = data.items.filter(item => item.enabled !== false);
    }
    if (Array.isArray(data.toast_phrases) && data.toast_phrases.length) {
      toastPhrases = data.toast_phrases;
    }
  } catch(e) {}
}

function renderPurchaseList() {
  const list = document.getElementById('purchaseList');
  if (!list) return;
  list.innerHTML = '';
  proofItems.forEach((p, i) => setTimeout(() => {
    const isBlue = (p.color || 'green') === 'blue';
    const letter = (p.name || '?')[0].toUpperCase();
    const el = document.createElement('div');
    el.className = 'purchase-item' + (isBlue ? ' pi-blue' : '');
    el.innerHTML = `
      <div class="pi-avatar">${letter}</div>
      <div class="pi-info">
        <div class="pi-name">${p.name} <span>purchased</span></div>
        <span class="pi-plan-badge">${mapPlan(p.plan)}</span>
      </div>
      <div class="pi-price">${p.price}</div>`;
    list.appendChild(el);
  }, i * 120));
}

function showToast() {
  if (!proofItems.length) return;
  const wrap = document.getElementById('toastWrap');
  const p = proofItems[Math.floor(Math.random() * proofItems.length)];
  const phrase = toastPhrases[Math.floor(Math.random() * toastPhrases.length)];
  const t = document.createElement('div');
  t.className = 'toast';
  t.innerHTML = `<div class="toast-dot"></div><div><div><span class="toast-name">${p.name}</span> purchased</div><div class="toast-time">${mapPlan(p.plan)} · ${phrase}</div></div>`;
  wrap.appendChild(t);
  setTimeout(() => t.classList.add('show'), 50);
  setTimeout(() => { t.classList.remove('show'); setTimeout(() => t.remove(), 400); }, 4000);
}

document.addEventListener('DOMContentLoaded', async () => {
  loadStats();
  await loadProofData();
  renderPurchaseList();
  setTimeout(() => { showToast(); setInterval(showToast, Math.random() * 7000 + 8000); }, 3000);
});
</script>
