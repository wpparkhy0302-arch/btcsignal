        <div class="price-plan">3 Months</div><div class="price-amount">$99</div><div class="price-period">USDT / 3 months (33 USDT/mo)</div>
        <div class="price-features">
          <div class="pf"><span class="pf-check">✓</span>Includes everything in the 1-month plan</div>
          <div class="pf"><span class="pf-check">✓</span>Save 6 USDT per month</div>
          <div class="pf"><span class="pf-check">✓</span>Priority support</div>
          <div class="pf"><span class="pf-check">✓</span>Early access to new features</div>
          <div class="pf"><span class="pf-check">✓</span>Free updates during subscription</div>
        </div>
        <a class="price-btn primary" href="/api/payment/create?plan=3month">Buy Now</a>
