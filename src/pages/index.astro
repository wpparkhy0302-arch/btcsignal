// Landing Page - BTC Signal AI (English)
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>BTC Signal AI — Real-Time Trading Signals</title>
<meta name="description" content="Get instant LONG/SHORT signals for BTC, ETH, SOL and BNB. AI-powered technical analysis with auto-calculated entry, target, and stop-loss prices.">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=IBM+Plex+Mono:wght@400;600&display=swap" rel="stylesheet">
<style>
:root{--bg:#0a0d14;--card:#13192a;--card2:#1a2236;--border:#1e2d47;--border2:#263654;--green:#06b66b;--green-bg:rgba(6,182,107,0.1);--red:#f04452;--blue:#3182f6;--blue-bg:rgba(49,130,246,0.1);--gold:#f5a623;--text:#e8edf5;--text2:#8b95a7;--text3:#4a5568;--r:12px;}
*{margin:0;padding:0;box-sizing:border-box;}html{scroll-behavior:smooth;}
body{background:var(--bg);color:var(--text);font-family:'Inter',sans-serif;font-size:15px;line-height:1.6;overflow-x:hidden;}
.mono{font-family:'IBM Plex Mono',monospace;}
.toast-wrap{position:fixed;bottom:28px;left:28px;z-index:999;display:flex;flex-direction:column;gap:10px;pointer-events:none;}
.toast{display:flex;align-items:center;gap:12px;background:var(--card2);border:1px solid var(--border2);border-left:3px solid var(--green);border-radius:10px;padding:12px 16px;font-size:13px;color:var(--text);box-shadow:0 8px 32px rgba(0,0,0,.5);transform:translateX(-120%);transition:transform .4s cubic-bezier(.34,1.56,.64,1);max-width:300px;pointer-events:none;}
.toast.show{transform:translateX(0);}
.toast-dot{width:8px;height:8px;border-radius:50%;background:var(--green);flex-shrink:0;animation:blink 1s ease-in-out infinite;}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}
.toast-name{font-weight:600;color:var(--green);}
.toast-time{font-size:11px;color:var(--text3);margin-top:2px;}
nav{position:fixed;top:0;left:0;right:0;z-index:100;background:rgba(10,13,20,.85);backdrop-filter:blur(12px);border-bottom:1px solid var(--border);padding:0 40px;}
.nav-inner{max-width:1100px;margin:0 auto;height:60px;display:flex;align-items:center;justify-content:space-between;}
.nav-logo{display:flex;align-items:center;gap:10px;}
.nav-logo-icon{width:32px;height:32px;border-radius:8px;background:var(--green);display:grid;place-items:center;font-weight:700;font-size:15px;color:#fff;}
.nav-logo-text{font-weight:700;font-size:16px;}
.nav-links{display:flex;gap:28px;font-size:14px;}
.nav-links a{color:var(--text2);text-decoration:none;transition:color .2s;}
.nav-links a:hover{color:var(--text);}
.nav-btn{padding:8px 18px;background:var(--green);color:#fff;border-radius:8px;font-size:13px;font-weight:600;text-decoration:none;}
@media(max-width:640px){.nav-links{display:none;}}
.hero{min-height:100vh;display:flex;align-items:center;justify-content:center;padding:120px 24px 80px;text-align:center;position:relative;overflow:hidden;}
.hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 70% 50% at 50% 20%,rgba(6,182,107,0.08) 0%,transparent 70%);pointer-events:none;}
.hero-badge{display:inline-flex;align-items:center;gap:8px;font-size:12px;font-weight:600;color:var(--green);background:var(--green-bg);border:1px solid rgba(6,182,107,.25);padding:5px 14px;border-radius:20px;margin-bottom:24px;}
.hero-badge-dot{width:6px;height:6px;border-radius:50%;background:var(--green);animation:blink 1.5s infinite;}
h1{font-size:clamp(36px,6vw,66px);font-weight:800;line-height:1.12;letter-spacing:-1.5px;margin-bottom:20px;}
h1 span{color:var(--green);}
.hero-sub{font-size:clamp(16px,2vw,19px);color:var(--text2);margin-bottom:36px;line-height:1.7;max-width:580px;margin-left:auto;margin-right:auto;}
.hero-btns{display:flex;gap:12px;justify-content:center;flex-wrap:wrap;margin-bottom:48px;}
.btn-primary{padding:14px 32px;background:var(--green);color:#fff;border-radius:10px;font-size:16px;font-weight:700;text-decoration:none;display:inline-block;}
.btn-ghost{padding:14px 28px;background:transparent;color:var(--text2);border:1px solid var(--border2);border-radius:10px;font-size:15px;font-weight:500;text-decoration:none;display:inline-block;}
.btn-trial{padding:14px 24px;background:var(--blue-bg);color:var(--blue);border:1px solid rgba(49,130,246,.3);border-radius:10px;font-size:14px;font-weight:600;text-decoration:none;display:inline-block;}
.hero-stats{display:flex;gap:40px;justify-content:center;flex-wrap:wrap;}
.stat-val{font-size:32px;font-weight:800;font-family:'IBM Plex Mono',monospace;}
.stat-lbl{font-size:12px;color:var(--text3);margin-top:2px;}
section{padding:80px 24px;}
.inner{max-width:1060px;margin:0 auto;}
.text-center{text-align:center;margin-bottom:48px;}
.sec-badge{display:inline-block;font-size:11px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--green);background:var(--green-bg);border:1px solid rgba(6,182,107,.2);padding:4px 12px;border-radius:20px;margin-bottom:14px;}
.sec-title{font-size:clamp(26px,4vw,40px);font-weight:800;letter-spacing:-0.5px;margin-bottom:12px;}
.sec-sub{font-size:16px;color:var(--text2);max-width:560px;}
.sec-sub.center{margin:0 auto;}
.feat-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:48px;}
@media(max-width:768px){.feat-grid{grid-template-columns:1fr 1fr;}}
@media(max-width:480px){.feat-grid{grid-template-columns:1fr;}}
.feat-card{background:var(--card);border:1px solid var(--border);border-radius:var(--r);padding:24px;}
.feat-icon{font-size:28px;margin-bottom:12px;}
.feat-title{font-size:15px;font-weight:700;margin-bottom:8px;}
.feat-desc{font-size:13px;color:var(--text2);line-height:1.7;}
.signal-preview{background:var(--card);border:1px solid var(--border);border-radius:16px;overflow:hidden;}
.preview-bar{background:var(--card2);border-bottom:1px solid var(--border);padding:12px 18px;display:flex;align-items:center;gap:10px;}
.preview-dots{display:flex;gap:6px;}
.pd{width:12px;height:12px;border-radius:50%;}
.preview-title{flex:1;text-align:center;font-size:13px;font-weight:600;color:var(--text2);}
.preview-live{display:flex;align-items:center;gap:6px;font-size:11px;font-weight:600;color:var(--green);}
.preview-live-dot{width:6px;height:6px;border-radius:50%;background:var(--green);animation:blink 1.5s infinite;}
.preview-body{padding:20px;}
.preview-signal{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:16px;}
.ps-badge{display:inline-block;font-size:11px;font-weight:700;background:var(--green);color:#fff;padding:2px 10px;border-radius:4px;margin-bottom:6px;}
.ps-name{font-size:22px;font-weight:700;color:var(--green);}
.ps-reason{font-size:12px;color:var(--text2);margin-top:4px;}
.ps-lev-lbl{font-size:11px;color:var(--text3);margin-bottom:4px;}
.ps-lev{font-size:22px;font-weight:700;font-family:'IBM Plex Mono',monospace;}
.preview-prices{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;}
.pp-card{background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:12px 14px;}
.pp-lbl{font-size:11px;font-weight:600;margin-bottom:4px;}
.pp-lbl.buy{color:var(--green);}
.pp-lbl.sell{color:var(--red);}
.pp-lbl.stop{color:var(--gold);}
.pp-val{font-size:15px;font-weight:700;font-family:'IBM Plex Mono',monospace;color:var(--text);}
.purchase-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:24px;flex-wrap:wrap;gap:12px;}
.purchase-live-badge{display:flex;align-items:center;gap:8px;font-size:13px;font-weight:600;color:var(--text2);background:var(--card2);border:1px solid var(--border);padding:6px 14px;border-radius:20px;}
.purchase-list{display:grid;grid-template-columns:repeat(2,1fr);gap:12px;}
@media(max-width:640px){.purchase-list{grid-template-columns:1fr;}}
.purchase-item{
  background:var(--bg);border:1px solid var(--border);border-left:3px solid var(--green);
  border-radius:12px;padding:16px 18px;display:flex;align-items:center;gap:14px;
  transition:border-color .2s;
}
.purchase-item.pi-blue{border-left-color:var(--blue);}
.pi-avatar{
  width:40px;height:40px;border-radius:50%;flex-shrink:0;
  background:var(--green-bg);border:1px solid rgba(6,182,107,.2);
  display:flex;align-items:center;justify-content:center;
  font-size:15px;font-weight:700;color:var(--green);
}
.pi-blue .pi-avatar{background:var(--blue-bg);border-color:rgba(49,130,246,.2);color:var(--blue);}
.pi-info{flex:1;min-width:0;overflow:hidden;}
.pi-name{font-size:14px;font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.pi-name span{color:var(--text2);font-weight:400;}
.pi-plan-badge{
  display:inline-block;font-size:11px;font-weight:600;margin-top:5px;
  background:var(--green-bg);color:var(--green);border:1px solid rgba(6,182,107,.2);
  padding:2px 9px;border-radius:20px;
}
.pi-blue .pi-plan-badge{background:var(--blue-bg);color:var(--blue);border-color:rgba(49,130,246,.2);}
.pi-price{font-size:13px;font-weight:700;font-family:'IBM Plex Mono',monospace;flex-shrink:0;color:var(--text);}
.reviews-sec{background:var(--card);border-top:1px solid var(--border);border-bottom:1px solid var(--border);}
.reviews-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;}
@media(max-width:768px){.reviews-grid{grid-template-columns:1fr 1fr;}}
@media(max-width:480px){.reviews-grid{grid-template-columns:1fr;}}
.review-card{background:var(--bg);border:1px solid var(--border);border-radius:var(--r);padding:20px;}
.review-top{display:flex;align-items:center;gap:12px;margin-bottom:12px;}
.review-avatar{font-size:28px;}
.review-stars{color:var(--gold);font-size:13px;margin-bottom:2px;}
.review-name{font-size:13px;font-weight:600;color:var(--text2);}
.review-text{font-size:13px;color:var(--text2);line-height:1.7;margin-bottom:12px;}
.review-tag{font-size:11px;font-weight:600;color:var(--green);background:var(--green-bg);border:1px solid rgba(6,182,107,.2);padding:3px 10px;border-radius:20px;display:inline-block;}
.pricing-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;}
@media(max-width:768px){.pricing-grid{grid-template-columns:1fr;max-width:400px;margin:0 auto;}}
.price-card{background:var(--card);border:1px solid var(--border);border-radius:16px;padding:28px;position:relative;}
.price-card.popular{border-color:var(--green);background:linear-gradient(135deg,var(--card),rgba(6,182,107,0.05));}
.popular-badge{position:absolute;top:-12px;left:50%;transform:translateX(-50%);font-size:12px;font-weight:700;background:var(--green);color:#fff;padding:3px 14px;border-radius:20px;white-space:nowrap;}
.price-plan{font-size:14px;font-weight:600;color:var(--text2);margin-bottom:10px;}
.price-amount{font-size:42px;font-weight:800;font-family:'IBM Plex Mono',monospace;color:var(--text);line-height:1;}
.price-period{font-size:13px;color:var(--text3);margin-bottom:20px;margin-top:4px;}
.price-features{display:flex;flex-direction:column;gap:8px;margin-bottom:24px;}
.pf{font-size:13px;color:var(--text2);display:flex;align-items:flex-start;gap:8px;}
.pf-check{color:var(--green);font-weight:700;flex-shrink:0;}
.price-btn{width:100%;padding:13px;border-radius:10px;font-size:14px;font-weight:700;cursor:pointer;border:none;display:block;text-align:center;text-decoration:none;box-sizing:border-box;}
.price-btn.primary{background:var(--green);color:#fff;}
.price-btn.ghost{background:transparent;color:var(--text2);border:1px solid var(--border2);}
.cta-sec{padding:80px 24px;background:linear-gradient(135deg,var(--card),rgba(6,182,107,0.05));}
footer{background:var(--card);border-top:1px solid var(--border);padding:28px 24px;text-align:center;font-size:12px;color:var(--text3);line-height:1.8;}
</style>
</head>
<body>
<div class="toast-wrap" id="toastWrap"></div>
<nav>
  <div class="nav-inner">
    <div class="nav-logo">
      <div class="nav-logo-icon">₿</div>
      <div class="nav-logo-text">BTC Signal AI</div>
    </div>
    <div class="nav-links">
      <a href="#features">Features</a>
      <a href="#reviews">Reviews</a>
      <a href="#pricing">Pricing</a>
    </div>
    <a class="nav-btn" href="#pricing">Start Now</a>
