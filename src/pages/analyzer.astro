// ════════════════════════════════════════
// BINANCE DATA
// ════════════════════════════════════════
async function fetchKlines(sym, interval, limit=200) {
  const url = `https://api.binance.com/api/v3/klines?symbol=${sym}&interval=${interval}&limit=${limit}`;
  try {
    const r = await fetch(url);
    if (!r.ok) throw new Error('HTTP ' + r.status);
    const raw = await r.json();
    if (!Array.isArray(raw)) throw new Error('Invalid response');
    return raw.map(d => ({
      t: d[0]/1000, o: +d[1], h: +d[2], l: +d[3], c: +d[4], v: +d[5]
    }));
  } catch(e) {
    throw new Error('Binance data load failed. Please access via https:// server.');
  }
}

async function fetchTicker(sym) {
  try {
    const r = await fetch(`https://api.binance.com/api/v3/ticker/24hr?symbol=${sym}`);
    if (!r.ok) throw new Error('HTTP ' + r.status);
    return r.json();
  } catch(e) {
    throw new Error('Binance ticker load failed. Please access via https:// server.');
  }
}

function connectTickerWS(sym) {
  if (tickerWs) tickerWs.close();
  tickerWs = new WebSocket(`wss://stream.binance.com:9443/ws/${sym.toLowerCase()}@ticker`);
  tickerWs.onmessage = e => {
    const d = JSON.parse(e.data);
    const price = +d.c;
    const pct = +d.P;
    document.getElementById('tkPrice').textContent = '$' + price.toLocaleString('en-US',{minimumFractionDigits:2,maximumFractionDigits:2});
    const chEl = document.getElementById('tkChange');
    chEl.textContent = (pct>=0?'+':'')+pct.toFixed(2)+'%';
    chEl.className = 'ticker-val mono ' + (pct>=0?'pos':'neg');
  };
  tickerWs.onopen = () => {
    document.getElementById('wsDot').className='ws-dot live';
    document.getElementById('wsLbl').textContent='LIVE';
  };
  tickerWs.onclose = () => {
    document.getElementById('wsDot').className='ws-dot';
    document.getElementById('wsLbl').textContent='Disconnected';
  };
}

// ════════════════════════════════════════
// TECHNICAL INDICATORS
// ════════════════════════════════════════
function calcSMA(data, period) {
  const result = [];
  for (let i=0; i<data.length; i++) {
    if (i < period-1) { result.push(null); continue; }
    const sum = data.slice(i-period+1, i+1).reduce((a,b)=>a+b, 0);
    result.push(sum/period);
  }
  return result;
}

function calcEMA(data, period) {
  const k = 2/(period+1);
  const result = [];
  let ema = null;
  for (let i=0; i<data.length; i++) {
    if (ema === null) { ema = data[i]; result.push(ema); continue; }
    ema = data[i]*k + ema*(1-k);
    result.push(ema);
  }
  return result;
}

function calcRSI(closes, period=14) {
  const gains=[], losses=[];
  for (let i=1; i<closes.length; i++) {
    const diff = closes[i]-closes[i-1];
    gains.push(Math.max(diff,0));
    losses.push(Math.max(-diff,0));
  }
  const result = new Array(period).fill(null);
  let avgG = gains.slice(0,period).reduce((a,b)=>a+b)/period;
  let avgL = losses.slice(0,period).reduce((a,b)=>a+b)/period;
  result.push(100 - 100/(1+(avgG/(avgL||0.0001))));
  for (let i=period; i<gains.length; i++) {
    avgG = (avgG*(period-1)+gains[i])/period;
    avgL = (avgL*(period-1)+losses[i])/period;
    result.push(100 - 100/(1+(avgG/(avgL||0.0001))));
  }
  return result;
}

function calcMACD(closes, fast=12, slow=26, signal=9) {
  const emaFast = calcEMA(closes, fast);
  const emaSlow = calcEMA(closes, slow);
  const macdLine = emaFast.map((v,i)=> v!==null&&emaSlow[i]!==null ? v-emaSlow[i] : null);
  const validMacd = macdLine.filter(v=>v!==null);
  const signalLine = calcEMA(validMacd, signal);
  const offset = macdLine.length - validMacd.length;
  const sigFull = new Array(offset).fill(null).concat(
    new Array(validMacd.length - signalLine.length).fill(null).concat(signalLine)
  );
  const histogram = macdLine.map((v,i)=>v!==null&&sigFull[i]!==null ? v-sigFull[i] : null);
  return { macdLine, signalLine: sigFull, histogram };
}

function calcBollinger(closes, period=20, mult=2) {
  const sma = calcSMA(closes, period);
  const upper=[], lower=[], bandwidth=[];
  for (let i=0; i<closes.length; i++) {
    if (sma[i]===null) { upper.push(null); lower.push(null); bandwidth.push(null); continue; }
    const slice = closes.slice(i-period+1, i+1);
    const std = Math.sqrt(slice.reduce((s,v)=>s+Math.pow(v-sma[i],2),0)/period);
    upper.push(sma[i]+mult*std);
    lower.push(sma[i]-mult*std);
    bandwidth.push(((sma[i]+mult*std)-(sma[i]-mult*std))/sma[i]*100);
  }
  return { mid:sma, upper, lower, bandwidth };
}

function calcVolumeMA(volumes, period=20) {
  return calcSMA(volumes, period);
}

// ── ADX (추세 강도) ──
function calcADX(kdata, period=14) {
  const highs = kdata.map(k=>k.h);
  const lows  = kdata.map(k=>k.l);
  const closes= kdata.map(k=>k.c);
  const trArr=[], dmPArr=[], dmNArr=[];
  for (let i=1; i<kdata.length; i++) {
    const hl = highs[i]-lows[i];
    const hpc= Math.abs(highs[i]-closes[i-1]);
    const lpc= Math.abs(lows[i]-closes[i-1]);
    trArr.push(Math.max(hl,hpc,lpc));
    const upMove  = highs[i]-highs[i-1];
    const downMove= lows[i-1]-lows[i];
    dmPArr.push(upMove>downMove&&upMove>0?upMove:0);
    dmNArr.push(downMove>upMove&&downMove>0?downMove:0);
  }
  const smooth = (arr, p) => {
    let s = arr.slice(0,p).reduce((a,b)=>a+b,0);
    const r=[s];
    for(let i=p;i<arr.length;i++){s=s-s/p+arr[i];r.push(s);}
    return r;
  };
  const sTR=smooth(trArr,period), sDMP=smooth(dmPArr,period), sDMN=smooth(dmNArr,period);
  const diP=sDMP.map((v,i)=>sTR[i]?100*v/sTR[i]:0);
  const diN=sDMN.map((v,i)=>sTR[i]?100*v/sTR[i]:0);
  const dx=diP.map((v,i)=>{const s=v+diN[i];return s?100*Math.abs(v-diN[i])/s:0;});
  const adxArr=calcSMA(dx,period);
  return { adx: adxArr, diP, diN };
}

// ── 스토캐스틱 RSI ──
function calcStochRSI(closes, rsiPeriod=14, stochPeriod=14) {
  const rsi = calcRSI(closes, rsiPeriod).filter(v=>v!==null);
  const result=[];
  for(let i=0;i<rsi.length;i++){
    if(i<stochPeriod-1){result.push(null);continue;}
    const slice=rsi.slice(i-stochPeriod+1,i+1);
    const lo=Math.min(...slice), hi=Math.max(...slice);
    result.push(hi===lo?50:(rsi[i]-lo)/(hi-lo)*100);
  }
  return result;
}

// ── OBV (누적 거래량) ──
function calcOBV(kdata) {
  const obv=[0];
  for(let i=1;i<kdata.length;i++){
    const prev=obv[obv.length-1];
    if(kdata[i].c>kdata[i-1].c) obv.push(prev+kdata[i].v);
    else if(kdata[i].c<kdata[i-1].c) obv.push(prev-kdata[i].v);
    else obv.push(prev);
  }
  return obv;
}

// ── Fibonacci (스윙 고점/저점 자동 탐지) ──
function calcFibonacci(kdata, swingLen=10) {
  const n = kdata.length;
  // 최근 100개 캔들에서 스윙 고점·저점 탐지
  const lookback = Math.min(100, n);
  const slice = kdata.slice(n - lookback);
  let swingHigh = -Infinity, swingLow = Infinity;
  let swingHighIdx = 0, swingLowIdx = 0;
  for(let i=swingLen; i<slice.length-swingLen; i++){
    const isHigh = slice.slice(i-swingLen,i).every(k=>k.h<=slice[i].h) &&
                   slice.slice(i+1,i+swingLen+1).every(k=>k.h<=slice[i].h);
    const isLow  = slice.slice(i-swingLen,i).every(k=>k.l>=slice[i].l) &&
                   slice.slice(i+1,i+swingLen+1).every(k=>k.l>=slice[i].l);
    if(isHigh && slice[i].h>swingHigh){ swingHigh=slice[i].h; swingHighIdx=i; }
    if(isLow  && slice[i].l<swingLow ){ swingLow =slice[i].l; swingLowIdx =i; }
  }
  if(swingHigh===-Infinity || swingLow===Infinity) return null;
  const range = swingHigh - swingLow;
  const levels = {
    '0':   swingHigh,
    '23.6': swingHigh - range*0.236,
    '38.2': swingHigh - range*0.382,
    '50':   swingHigh - range*0.5,
    '61.8': swingHigh - range*0.618,
    '78.6': swingHigh - range*0.786,
    '100':  swingLow,
  };
  // 추세 방향: 고점이 저점보다 나중이면 하락추세
  const trend = swingHighIdx > swingLowIdx ? 'down' : 'up';
  return { levels, swingHigh, swingLow, trend, range };
}

// ── 거래량 프로파일 POC ──
function calcVolumeProfile(kdata, bins=20) {
  const highs  = kdata.map(k=>k.h);
  const lows   = kdata.map(k=>k.l);
  const volumes= kdata.map(k=>k.v);
  const priceMin = Math.min(...lows);
  const priceMax = Math.max(...highs);
  const binSize  = (priceMax-priceMin)/bins;
  const profile  = new Array(bins).fill(0);
  kdata.forEach((k,i)=>{
    const lo = Math.floor((k.l-priceMin)/binSize);
    const hi = Math.ceil((k.h-priceMin)/binSize);
    for(let b=Math.max(0,lo); b<Math.min(bins,hi+1); b++){
      profile[b] += volumes[i]/(hi-lo+1);
    }
  });
  let maxVol=0, pocBin=0;
  profile.forEach((v,i)=>{ if(v>maxVol){maxVol=v;pocBin=i;} });
  const poc = priceMin + (pocBin+0.5)*binSize;
  return { poc, priceMin, priceMax, profile };
}

// ── Candle Pattern 감지 ──
function detectCandlePattern(kdata) {
  const n = kdata.length;
  if(n<3) return { name:'None', signal:'neu', score:0 };
  const c  = kdata[n-1]; // 현재 캔들
  const p1 = kdata[n-2]; // 1개 전
  const p2 = kdata[n-3]; // 2개 전

  const body    = c=>Math.abs(c.c-c.o);
  const range   = c=>c.h-c.l;
  const isBull  = c=>c.c>c.o;
  const isBear  = c=>c.c<c.o;
  const upperW  = c=>isBull(c)?c.h-c.c:c.h-c.o;
  const lowerW  = c=>isBull(c)?c.o-c.l:c.c-c.l;

  // 망치형 (Hammer) — 하락 후 저점에서 긴 아래꼬리
  if(lowerW(c)>=body(c)*2 && upperW(c)<=body(c)*0.5 && isBull(c)){
    return { name:'망치형', signal:'bull', score:2 };
  }
  // 슈팅스타 — 상승 후 고점에서 긴 위꼬리
  if(upperW(c)>=body(c)*2 && lowerW(c)<=body(c)*0.5 && isBear(c)){
    return { name:'슈팅스타', signal:'bear', score:-2 };
  }
  // 불리시 인걸핑
  if(isBear(p1) && isBull(c) && c.o<p1.c && c.c>p1.o){
    return { name:'불리시 인걸핑', signal:'bull', score:3 };
  }
  // 베어리시 인걸핑
  if(isBull(p1) && isBear(c) && c.o>p1.c && c.c<p1.o){
    return { name:'베어리시 인걸핑', signal:'bear', score:-3 };
  }
  // 모닝스타
  if(isBear(p2) && body(p1)<body(p2)*0.3 && isBull(c) && c.c>p2.o){
    return { name:'모닝스타', signal:'bull', score:4 };
  }
  // 이브닝스타
  if(isBull(p2) && body(p1)<body(p2)*0.3 && isBear(c) && c.c<p2.o){
    return { name:'이브닝스타', signal:'bear', score:-4 };
  }
  // 도지
  if(body(c)<range(c)*0.1){
    return { name:'도지', signal:'neu', score:0 };
  }
  return { name:'None', signal:'neu', score:0 };
}

// ════════════════════════════════════════
// SIGNAL ENGINE
// ════════════════════════════════════════
function generateSignal(kdata) {
  const closes = kdata.map(k=>k.c);
  const volumes = kdata.map(k=>k.v);
  const n = closes.length;
  const last = n-1;

  // 기존 지표
  const rsi    = calcRSI(closes, 14);
  const macd   = calcMACD(closes);
  const bb     = calcBollinger(closes, 20, 2);
  const ma20   = calcSMA(closes, 20);
  const ma50   = calcSMA(closes, 50);
  const ma200  = calcSMA(closes, 200);
  const ema12  = calcEMA(closes, 12);
  const ema26  = calcEMA(closes, 26);
  const volMA  = calcVolumeMA(volumes, 20);

  // 신규 지표
  const adxData    = calcADX(kdata, 14);
  const stochRSI   = calcStochRSI(closes, 14, 14);
  const obv        = calcOBV(kdata);
  const fib        = calcFibonacci(kdata, 10);
  const vp         = calcVolumeProfile(kdata, 30);
  const candle     = detectCandlePattern(kdata);

  const price        = closes[last];
  const rsiVal       = rsi[last];
  const macdVal      = macd.macdLine[last];
  const macdSig      = macd.signalLine[last];
  const macdHist     = macd.histogram[last];
  const macdHistPrev = macd.histogram[last-1];
  const bbUpper      = bb.upper[last];
  const bbLower      = bb.lower[last];
  const bbMid        = bb.mid[last];
  const ma20Val      = ma20[last];
  const ma50Val      = ma50[last];
  const ma200Val     = ma200[last];
  const ema12Val     = ema12[last];
  const ema26Val     = ema26[last];
  const volNow       = volumes[last];
  const volMAVal     = volMA[last];
  const adxVal       = adxData.adx[adxData.adx.length-1];
  const stochVal     = stochRSI[stochRSI.length-1];
  const obvNow       = obv[last];
  const obvPrev      = obv[last-5];
  const poc          = vp?.poc;

  let score = 0;
  const reasons = [], bearReasons = [];

  // ── RSI ──
  if (rsiVal < 30)      { score += 2; reasons.push('RSI 과SELL(' + rsiVal.toFixed(1) + ')'); }
  else if (rsiVal < 45) { score += 1; reasons.push('RSI Low Zone (' + rsiVal.toFixed(1) + ')'); }
  else if (rsiVal > 70) { score -= 2; bearReasons.push('RSI 과BUY(' + rsiVal.toFixed(1) + ')'); }
  else if (rsiVal > 60) { score -= 1; bearReasons.push('RSI High Zone (' + rsiVal.toFixed(1) + ')'); }

  // ── MACD ──
  if (macdVal !== null && macdSig !== null) {
    if (macdVal > macdSig && macdHistPrev < 0 && macdHist > 0) { score += 2; reasons.push('MACD Golden Cross'); }
    else if (macdVal > macdSig) { score += 1; reasons.push('MACD Bullish'); }
    else if (macdVal < macdSig && macdHistPrev > 0 && macdHist < 0) { score -= 2; bearReasons.push('MACD Death Cross'); }
    else if (macdVal < macdSig) { score -= 1; bearReasons.push('MACD Bearish'); }
  }

  // ── 볼린저 ──
  if (bbLower && price <= bbLower)      { score += 2; reasons.push('BB Lower Band Break'); }
  else if (bbUpper && price >= bbUpper) { score -= 2; bearReasons.push('BB Upper Band Break'); }
  else if (bbMid && price > bbMid)      { score += 1; reasons.push('Above BB Midline'); }
  else if (bbMid && price < bbMid)      { score -= 1; bearReasons.push('Below BB Midline'); }

  // ── 이동평균 ──
  if (ma20Val && ma50Val) {
    if (price > ma20Val && price > ma50Val) { score += 1; reasons.push('Above MA20&MA50'); }
    else if (price < ma20Val && price < ma50Val) { score -= 1; bearReasons.push('Below MA20&MA50'); }
    if (ma20Val > ma50Val) { score += 1; reasons.push('MA20>MA50 Uptrend'); }
    else { score -= 1; bearReasons.push('MA20<MA50 Downtrend'); }
  }
  if (ma200Val) {
    if (price > ma200Val) { score += 1; reasons.push('Above MA200 (Long-term Uptrend)'); }
    else { score -= 1; bearReasons.push('Below MA200 (Long-term Downtrend)'); }
  }

  // ── 거래량 ──
  if (volMAVal && volNow > volMAVal * 1.5) {
    if (score > 0) { score += 1; reasons.push('Volume Surge (Trend Confirmed)'); }
    else { score -= 1; bearReasons.push('Volume Surge (Bearish Pressure)'); }
  }

  // ── ADX (추세 강도) ──
  let adxBoost = 1.0;
  if (adxVal !== null && adxVal !== undefined) {
    if (adxVal < 20) {
      // 횡보장 — 점수 40% 감쇄
      adxBoost = 0.6;
      bearReasons.push('ADX ' + adxVal.toFixed(0) + ' (Ranging, Signal Weakened)');
    } else if (adxVal >= 25) {
      score += (score > 0 ? 1 : score < 0 ? -1 : 0);
      reasons.push('ADX ' + adxVal.toFixed(0) + ' (Strong Trend)');
    }
  }

  // ── 스토캐스틱 RSI ──
  if (stochVal !== null && stochVal !== undefined) {
    if (stochVal < 20)      { score += 1; reasons.push('StochRSI 과SELL'); }
    else if (stochVal > 80) { score -= 1; bearReasons.push('StochRSI 과BUY'); }
  }

  // ── OBV ──
  if (obvNow !== undefined && obvPrev !== undefined) {
    if (obvNow > obvPrev * 1.05) { score += 1; reasons.push('OBV 상승(BUY세 증가)'); }
    else if (obvNow < obvPrev * 0.95) { score -= 1; bearReasons.push('OBV 하락(SELL세 증가)'); }
  }

  // ── Candle Pattern ──
  if (candle.score !== 0) {
    score += candle.score;
    if (candle.score > 0) reasons.push('Candle Pattern: ' + candle.name);
    else bearReasons.push('Candle Pattern: ' + candle.name);
  }

  // ── Fibonacci ──
  let fibLevel = null, fibNearLevel = null;
  if (fib) {
    const lvls = Object.entries(fib.levels);
    let minDist = Infinity;
    lvls.forEach(([pct, val]) => {
      const dist = Math.abs(price - val) / price;
      if (dist < minDist) { minDist = dist; fibNearLevel = pct; fibLevel = val; }
    });
    if (minDist < 0.005) { // 0.5% 이내면 레벨 근처
      if (fibNearLevel === '61.8' || fibNearLevel === '50') {
        score += (fib.trend==='up' ? 2 : -2);
        if (fib.trend==='up') reasons.push('Fib ' + fibNearLevel + '% 지지 근처');
        else bearReasons.push('Fib ' + fibNearLevel + '% 저항 근처');
      } else if (fibNearLevel === '38.2' || fibNearLevel === '23.6') {
        score += (fib.trend==='up' ? 1 : -1);
        if (fib.trend==='up') reasons.push('Fib ' + fibNearLevel + '% 근처');
        else bearReasons.push('Fib ' + fibNearLevel + '% 근처');
      }
    }
  }

  // ── POC (거래량 프로파일) ──
  if (poc) {
    const pocDist = Math.abs(price - poc) / price;
    if (pocDist < 0.003) {
      // POC 바로 위 or 아래
      if (price >= poc) { score += 1; reasons.push('Above POC Support'); }
      else { score -= 1; bearReasons.push('Below POC Resistance'); }
    } else if (price > poc) { score += 1; reasons.push('Above POC (Buy Dominant)'); }
    else { score -= 1; bearReasons.push('Below POC (Sell Dominant)'); }
  }

  // ADX 횡보장 감쇄 적용
  score = Math.round(score * adxBoost);

  // ── 포지션 결정 (최대 ±15점) ──
  let position, posName, confidence, leverageRec;
  const absScore = Math.abs(score);

  if      (score >= 8)  { position='LONG';  posName='롱 (LONG)';  confidence=Math.min(55+absScore*3, 93); leverageRec='3x ~ 5x'; }
  else if (score >= 5)  { position='LONG';  posName='롱 (LONG)';  confidence=Math.min(50+absScore*3, 83); leverageRec='2x ~ 3x'; }
  else if (score >= 3)  { position='LONG';  posName='롱 (LONG)';  confidence=Math.min(50+absScore*2, 72); leverageRec='1x ~ 2x'; }
  else if (score <= -8) { position='SHORT'; posName='숏 (SHORT)'; confidence=Math.min(55+absScore*3, 93); leverageRec='3x ~ 5x'; }
  else if (score <= -5) { position='SHORT'; posName='숏 (SHORT)'; confidence=Math.min(50+absScore*3, 83); leverageRec='2x ~ 3x'; }
  else if (score <= -3) { position='SHORT'; posName='숏 (SHORT)'; confidence=Math.min(50+absScore*2, 72); leverageRec='1x ~ 2x'; }
  else                  { position='HOLD';  posName='관망 (HOLD)'; confidence=50; leverageRec='0x'; }

  // ── 가격 계산 (Fibonacci + POC 반영) ──
  const atr    = calcATR(kdata, 14);
  const atrVal = atr[last] || price * 0.02;
  const fmt    = v => '$' + v.toLocaleString('en-US',{minimumFractionDigits:2,maximumFractionDigits:2});

  let entryPrice, targetPrice, stopLoss, rrRatio;

  if (position === 'LONG') {
    // 진입가: Fibonacci 61.8% or POC 중 가까운 쪽, 없으면 Price
    entryPrice = price;
    if (fib && fib.levels['61.8'] && fib.levels['61.8'] < price * 1.005) {
      entryPrice = fib.levels['61.8'];
    } else if (poc && poc < price * 1.002) {
      entryPrice = poc;
    }
    // 목표가: Fibonacci 0%(고점) 우선, 없으면 ATR×3
    targetPrice = fib ? fib.levels['0'] : price + atrVal * 3;
    if (targetPrice <= price) targetPrice = price + atrVal * 3;
    // 손절가: Fibonacci 78.6% or POC 아래 ATR×1.5
    stopLoss = fib ? fib.levels['78.6'] : price - atrVal * 1.5;
    if (stopLoss >= price) stopLoss = price - atrVal * 1.5;
  } else if (position === 'SHORT') {
    entryPrice = price;
    if (fib && fib.levels['38.2'] && fib.levels['38.2'] > price * 0.995) {
      entryPrice = fib.levels['38.2'];
    } else if (poc && poc > price * 0.998) {
      entryPrice = poc;
    }
    targetPrice = fib ? fib.levels['100'] : price - atrVal * 3;
    if (targetPrice >= price) targetPrice = price - atrVal * 3;
    stopLoss = fib ? fib.levels['23.6'] : price + atrVal * 1.5;
    if (stopLoss <= price) stopLoss = price + atrVal * 1.5;
  } else {
    entryPrice  = price;
    targetPrice = null;
    stopLoss    = null;
  }

  // R:R 계산
  if (targetPrice && stopLoss) {
    const reward = Math.abs(targetPrice - entryPrice);
    const risk   = Math.abs(stopLoss - entryPrice);
    const rr     = risk > 0 ? (reward/risk).toFixed(1) : '—';
    rrRatio = '1 : ' + rr;
  } else {
    rrRatio = '—';
  }

  const mainReason = (position==='LONG' ? reasons : bearReasons).slice(0,3).join(' · ') || '지표 혼조';
  const tfStratMap = { '1m':'스캘핑','5m':'단타','15m':'단타','1h':'스윙','4h':'스윙','1d':'포지션' };
  const holdMap    = { '1m':'5~30분','5m':'30분~2시간','15m':'1~4시간','1h':'1~3일','4h':'3~7일','1d':'1~4주' };

  return {
    position, posName, confidence, leverageRec,
    entryPrice:  fmt(entryPrice),
    targetPrice: targetPrice ? fmt(targetPrice) : '—',
    stopLoss:    stopLoss    ? fmt(stopLoss)    : '—',
    rrRatio, mainReason, score,
    indicators: {
      rsi:     { val: rsiVal?.toFixed(1), sentiment: rsiVal<30?'bull':rsiVal>70?'bear':'neu', sub: rsiVal<30?'과SELL':rsiVal>70?'과BUY':'중립' },
      macd:    { val: macdVal?.toFixed(2), sentiment: macdVal>macdSig?'bull':'bear', sub: macdVal>macdSig?'강세':'약세' },
      bbPos:   { val: bbMid?((price-bbMid)/(bbUpper-bbMid)*100).toFixed(0)+'%':'—', sentiment: price<bbLower?'bull':price>bbUpper?'bear':'neu', sub: price<bbLower?'Lower Break':price>bbUpper?'Upper Break':'Mid Zone' },
      ma:      { val: ma20Val?fmt(ma20Val):'—', sentiment: price>ma20Val?'bull':'bear', sub: price>ma20Val?'상회':'하회' },
      macd200: { val: ma200Val?fmt(ma200Val):'—', sentiment: price>ma200Val?'bull':'bear', sub: price>ma200Val?'장기 상승':'장기 하락' },
      vol:     { val: volMAVal?(volNow/volMAVal*100).toFixed(0)+'%':'—', sentiment: volNow>volMAVal*1.3?'bull':volNow<volMAVal*0.7?'bear':'neu', sub: volNow>volMAVal*1.3?'평균 이상':'평균 이하' },
      score:   { val: (score>0?'+':'')+score, sentiment: score>0?'bull':score<0?'bear':'neu', sub: 'Total Score(/15)' },
      adx:     { val: adxVal?adxVal.toFixed(0):'—', sentiment: adxVal>=25?'bull':adxVal<20?'bear':'neu', sub: adxVal>=25?'강한 추세':adxVal<20?'횡보장':'약한 추세' },
      stochRsi:{ val: stochVal?stochVal.toFixed(0):'—', sentiment: stochVal<20?'bull':stochVal>80?'bear':'neu', sub: stochVal<20?'과SELL':stochVal>80?'과BUY':'중립' },
      fib:     { val: fibNearLevel?fibNearLevel+'%':'—', sentiment: fib&&fib.trend==='up'?'bull':'bear', sub: fibNearLevel?'피보 근처':'레벨 없음' },
      poc:     { val: poc?fmt(poc):'—', sentiment: poc&&price>poc?'bull':'bear', sub: poc&&price>poc?'POC 상회':'POC 하회' },
      candle:  { val: candle.name, sentiment: candle.signal, sub: candle.score>0?'BUY신호':candle.score<0?'SELL신호':'중립' },
      ema:     { val: ema12Val?fmt(ema12Val):'—', sentiment: ema12Val>ema26Val?'bull':'bear', sub: ema12Val>ema26Val?'Short-term Up':'Short-term Down' },
    },
    tfStrategy:    tfStratMap[tf] || '단타',
    holdingPeriod: holdMap[tf] || '—',
    analysis: buildAnalysis(position, reasons, bearReasons, rsiVal, macdVal, macdSig, price, bbLower, bbUpper, ma20Val, ma50Val),
    strategy: buildStrategy(position, fmt(entryPrice), targetPrice?fmt(targetPrice):'—', stopLoss?fmt(stopLoss):'—'),
    riskWarn: buildRisk(position, rsiVal, score),
  };
}

function calcATR(kdata, period=14) {
  const tr = kdata.map((k,i) => {
    if (i===0) return k.h-k.l;
    const prevC = kdata[i-1].c;
    return Math.max(k.h-k.l, Math.abs(k.h-prevC), Math.abs(k.l-prevC));
  });
  return calcSMA(tr, period);
}

function buildAnalysis(pos, bull, bear, rsi, macdV, macdS, price, bbL, bbU, ma20, ma50) {
  const bullStr = bull.slice(0,3).join(', ');
  const bearStr = bear.slice(0,3).join(', ');
  if (pos==='LONG') return `현재 ${bullStr} 신호가 감지되어 BUY 우위 상황입니다. RSI ${rsi?.toFixed(1)}으로 ${rsi<30?'과SELL권에서 반등 가능성이 높습니다':'상승 모멘텀이 유지되고 있습니다'}. MACD는 ${macdV>macdS?'시그널선 위에서 강세 흐름을 나타냅니다':'크로스 이후 상승 전환 신호입니다'}. ${bearStr?'단, '+bearStr+' 리스크도 존재하므로 Stop Loss을 반드시 설정하세요.':'지표 종합 시 BUY 진입이 유리한 구간입니다.'}`;
  if (pos==='SHORT') return `현재 ${bearStr} 신호가 감지되어 SELL 우위 상황입니다. RSI ${rsi?.toFixed(1)}으로 ${rsi>70?'과BUY권에서 조정 가능성이 높습니다':'하락 모멘텀이 강화되고 있습니다'}. MACD는 ${macdV<macdS?'시그널선 아래에서 약세 흐름입니다':'데드크로스 이후 하락 전환 신호입니다'}. ${bullStr?'단, '+bullStr+' 반등 신호도 있으니 Stop Loss을 철저히 지키세요.':'지표 종합 시 숏 진입이 유리한 구간입니다.'}`;
  return `Mixed BUY/SELL signals with no clear direction. Bullish: ${bullStr||'None'}. 약세 신호: ${bearStr||'None'}. 변동성이 낮고 방향이 불분명하므로 추가 캔들을 관찰 후 진입을 결정하는 것이 좋습니다.`;
}

function buildStrategy(pos, entry, target, stop) {
  if (pos==='LONG') return `Consider scaling in near ${entry}. Take 50% profit at ${target}, then trail the rest. Exit immediately if price breaks ${stop} to limit losses.`;
  if (pos==='SHORT') return `Enter SHORT near ${entry} targeting ${target}. Set stop loss at ${stop}, and close half the position when price reaches midway to reduce risk.`;
  return `현재는 관망을 권장합니다. 명확한 돌파 or 이탈 캔들이 나올 때까지 포지션을 보유하지 말고 기다리세요. RSI 30 이하 or 70 이상, MACD 크로스 발생 시 진입을 검토하세요.`;
}

function buildRisk(pos, rsi, score) {
  const risks = [];
  if (Math.abs(score)<4) risks.push('신호 강도가 약하여 변동성에 취약합니다');
  if (rsi>65 && pos==='LONG') risks.push('RSI 고점권으로 단기 조정 가능성 있음');
  if (rsi<35 && pos==='SHORT') risks.push('RSI 저점권으로 단기 반등 가능성 있음');
  risks.push('Always respect your stop loss when using leverage.');
  risks.push('This signal is for reference only. All investment decisions are your own responsibility.');
  return risks.slice(0,3).join('. ') + '.';
}

