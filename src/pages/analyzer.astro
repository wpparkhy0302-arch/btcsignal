let chart = null, candleSeries = null, chartWs = null;
let chartSymbol = 'BTCUSDT', chartTf = '15m';
let chartInited = false;

async function initChart() {
  // LightweightCharts 로드 확인
  if (typeof LightweightCharts === 'undefined') {
    document.getElementById('chartWsLbl').textContent = 'Loading library...';
    await new Promise(r => setTimeout(r, 800));
    if (typeof LightweightCharts === 'undefined') {
      document.getElementById('chartWsLbl').textContent = 'Library load failed - please refresh';
      return;
    }
  }

  // 심볼/TF 신호탭과 동기화
  chartSymbol = symbol;
  chartTf = tf;
  const csEl = document.getElementById('chartSymSelect');
  const ctEl = document.getElementById('chartTfSelect');
  if (csEl) csEl.value = chartSymbol;
  if (ctEl) ctEl.value = chartTf;

  const container = document.getElementById('chart-container');
  if (!container) return;

  if (!chartInited) {
    chartInited = true;
    try {
      chart = LightweightCharts.createChart(container, {
        width: container.clientWidth,
        height: 440,
        layout: { background:{color:'#161b27'}, textColor:'#8b95a7' },
        grid: { vertLines:{color:'#252e42'}, horzLines:{color:'#252e42'} },
        crosshair: { mode: LightweightCharts.CrosshairMode.Normal },
        rightPriceScale: { borderColor:'#252e42' },
        timeScale: { borderColor:'#252e42', timeVisible:true, secondsVisible:false },
        handleScroll: true,
        handleScale: true,
      });
      candleSeries = chart.addCandlestickSeries({
        upColor:'#06b66b', downColor:'#f04452',
        borderUpColor:'#06b66b', borderDownColor:'#f04452',
        wickUpColor:'#06b66b', wickDownColor:'#f04452',
      });
      window.addEventListener('resize', () => {
        if (chart) chart.applyOptions({ width: container.clientWidth });
      });
    } catch(e) {
      console.error('차트 생성 실패:', e);
      document.getElementById('chartWsLbl').textContent = '차트 생성 실패: ' + e.message;
      chartInited = false;
      return;
    }
  }

  await loadChartData();
  connectChartWS();
}

async function loadChartData() {
  if (!candleSeries) return;
  const lbl = document.getElementById('chartWsLbl');
  lbl.textContent = 'Loading chart data...';
  try {
    const url = `https://api.binance.com/api/v3/klines?symbol=${chartSymbol}&interval=${chartTf}&limit=500`;
    const res = await fetch(url);
    if (!res.ok) throw new Error('HTTP ' + res.status);
    const raw = await res.json();
    if (!Array.isArray(raw) || raw.length === 0) throw new Error('No data');
    const candles = raw.map(d => ({
      time: Math.floor(d[0] / 1000),
      open:  parseFloat(d[1]),
      high:  parseFloat(d[2]),
      low:   parseFloat(d[3]),
      close: parseFloat(d[4]),
    }));
    candleSeries.setData(candles);
    chart.timeScale().fitContent();
    lbl.textContent = `LIVE · ${chartSymbol} ${chartTf}`;
  } catch(e) {
    console.error('차트 데이터 로드 실패:', e);
    lbl.textContent = 'Load failed: ' + e.message;
  }
}

function connectChartWS() {
  if (chartWs) { chartWs.close(); chartWs = null; }

  const streamUrl = `wss://stream.binance.com:9443/ws/${chartSymbol.toLowerCase()}@kline_${chartTf}`;
  chartWs = new WebSocket(streamUrl);

  chartWs.onopen = () => {
    document.getElementById('chartWsDot').className = 'ws-dot live';
    document.getElementById('chartWsLbl').textContent = 'LIVE · ' + chartSymbol + ' ' + chartTf;
  };
  chartWs.onclose = () => {
    document.getElementById('chartWsDot').className = 'ws-dot';
    document.getElementById('chartWsLbl').textContent = 'Disconnected (reconnecting...)';
    // 5초 후 자동 재연결
    setTimeout(() => {
      if (document.getElementById('panel-chart').classList.contains('active')) {
        connectChartWS();
      }
    }, 5000);
  };
  chartWs.onerror = () => {
    document.getElementById('chartWsLbl').textContent = 'Connection error';
  };
  chartWs.onmessage = e => {
    try {
      const msg = JSON.parse(e.data);
      const k = msg.k;
      if (!k || !candleSeries) return;
      const candle = {
        time:  Math.floor(parseInt(k.t) / 1000),
        open:  parseFloat(k.o),
        high:  parseFloat(k.h),
        low:   parseFloat(k.l),
        close: parseFloat(k.c),
      };
      candleSeries.update(candle);
    } catch(err) { console.error('WS 업데이트 오류:', err); }
  };
}

function onChartSymChange() {
  chartSymbol = document.getElementById('chartSymSelect').value;
  if (chartInited) { loadChartData(); connectChartWS(); }
}
function onChartTfChange() {
  chartTf = document.getElementById('chartTfSelect').value;
  if (chartInited) { loadChartData(); connectChartWS(); }
}

// ════════════════════════════════════════
// INIT
// ════════════════════════════════════════
function init() {
  connectTickerWS(symbol);
  runAnalysis();
  startAutoRefresh();
}
</script>
</body>
