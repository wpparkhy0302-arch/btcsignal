async function runAnalysis() {
  const btn = document.getElementById('refreshBtn');
  btn.disabled = true; btn.textContent = 'Analyzing...';
  document.getElementById('analysisArea').innerHTML = '<div class="loading-state"><div class="spin"></div><div>Calculating indicators...</div></div>';

  try {
    const [data, ticker] = await Promise.all([
      fetchKlines(symbol, tf, 300),
      fetchTicker(symbol)
    ]);
    klines = data;

    // 티커 업데이트
    const price = +ticker.lastPrice;
    const pct = +ticker.priceChangePercent;
    document.getElementById('tkPrice').textContent = '$' + price.toLocaleString('en-US',{minimumFractionDigits:2,maximumFractionDigits:2});
    const chEl = document.getElementById('tkChange');
    chEl.textContent = (pct>=0?'+':'')+pct.toFixed(2)+'%';
    chEl.className = 'ticker-val mono '+(pct>=0?'pos':'neg');
    document.getElementById('tkHigh').textContent = '$' + (+ticker.highPrice).toLocaleString('en-US',{minimumFractionDigits:2,maximumFractionDigits:2});
    document.getElementById('tkLow').textContent = '$' + (+ticker.lowPrice).toLocaleString('en-US',{minimumFractionDigits:2,maximumFractionDigits:2});
    const vol = +ticker.quoteVolume;
    document.getElementById('tkVol').textContent = vol>1e9?(vol/1e9).toFixed(2)+'B':(vol/1e6).toFixed(0)+'M';

    const sig = generateSignal(data);
    renderAnalysis(sig, ticker);

  } catch(e) {
    const isLocal = location.protocol === 'file:';
    const msg = isLocal
      ? '⚠️ Binance API is blocked in local file mode.<br><br>👉 Upload to a server and access via <b>https://</b> for it to work properly!'
      : '❌ Data load failed: ' + e.message;
    document.getElementById('analysisArea').innerHTML = `<div class="loading-state" style="color:var(--text2);line-height:2">${msg}</div>`;
  }
  btn.disabled = false; btn.textContent = '🔄 Refresh Analysis';
}

