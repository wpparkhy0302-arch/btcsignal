<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>BTC Signal AI v3</title>
<script src="https://cdn.jsdelivr.net/npm/lightweight-charts@4.1.3/dist/lightweight-charts.standalone.production.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;600&display=swap" rel="stylesheet">
<style is:global>
:root {
  --bg:#0e1117; --card:#161b27; --card2:#1c2333;
  --border:#252e42; --border2:#2d3a52;
  --long:#06b66b; --long-bg:rgba(6,182,107,0.1);
  --short:#f04452; --short-bg:rgba(240,68,82,0.1);
  --hold:#f5a623; --hold-bg:rgba(245,166,35,0.1);
  --blue:#3182f6; --blue-bg:rgba(49,130,246,0.1);
  --text:#e8edf5; --text2:#8b95a7; --text3:#556070;
  --r:10px; --r-sm:6px;
}
*{margin:0;padding:0;box-sizing:border-box;}
body{background:var(--bg);color:var(--text);font-family:'Noto Sans KR',sans-serif;min-height:100vh;font-size:14px;line-height:1.5;}
.mono{font-family:'IBM Plex Mono',monospace;}

/* ── License Gate ── */
.lg{position:fixed;inset:0;background:var(--bg);display:flex;align-items:center;justify-content:center;z-index:9999;}
.lg.hidden{display:none;}
.lg-box{background:var(--card);border:1px solid var(--border);border-radius:16px;padding:40px 36px;width:100%;max-width:400px;text-align:center;}
.lg-logo{width:52px;height:52px;border-radius:12px;background:var(--long);display:grid;place-items:center;font-size:22px;font-weight:700;color:#fff;margin:0 auto 14px;}
.lg-badge{display:inline-flex;align-items:center;gap:6px;font-size:12px;font-weight:600;color:var(--long);background:var(--long-bg);border:1px solid rgba(6,182,107,.3);padding:3px 12px;border-radius:20px;margin-bottom:18px;}
.lg-dot{width:5px;height:5px;border-radius:50%;background:var(--long);animation:pulse 1.5s infinite;}
.lg-title{font-size:22px;font-weight:700;margin-bottom:6px;}
.lg-sub{font-size:13px;color:var(--text2);margin-bottom:28px;line-height:1.6;}
.lg-input{width:100%;padding:13px 16px;background:var(--bg);border:1px solid var(--border);border-radius:10px;font-size:14px;color:var(--text);margin-bottom:12px;font-family:'IBM Plex Mono',monospace;letter-spacing:1px;text-align:center;outline:none;}
.lg-input:focus{border-color:var(--long);}
.lg-input::placeholder{letter-spacing:0;color:var(--text3);font-family:'Noto Sans KR',sans-serif;}
.lg-btn{width:100%;padding:13px;background:var(--long);color:#fff;font-size:15px;font-weight:700;border:none;border-radius:10px;cursor:pointer;}
.lg-btn:hover{opacity:.88;}
.lg-error{font-size:12px;color:var(--short);margin-top:10px;min-height:18px;}
.lg-info{font-size:11px;color:var(--text3);margin-top:20px;line-height:1.7;}

/* ── Layout ── */
.wrap{max-width:1080px;margin:0 auto;padding:24px 20px;}
header{display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;padding-bottom:18px;border-bottom:1px solid var(--border);}
.hd-left{display:flex;align-items:center;gap:12px;}
.logo{width:36px;height:36px;border-radius:8px;background:var(--long);display:grid;place-items:center;font-size:16px;font-weight:700;color:#fff;}
.hd-title{font-size:18px;font-weight:700;}
.hd-sub{font-size:12px;color:var(--text2);margin-top:1px;}
.hd-badge{font-size:11px;font-weight:600;color:var(--long);background:var(--long-bg);border:1px solid rgba(6,182,107,.3);padding:3px 10px;border-radius:20px;}

/* ── Tabs ── */
.tabs{display:flex;background:var(--card);border:1px solid var(--border);border-radius:var(--r);padding:4px;gap:0;margin-bottom:20px;}
.tab{flex:1;padding:9px 16px;border-radius:8px;font-size:13px;font-weight:500;color:var(--text2);cursor:pointer;transition:all .18s;text-align:center;border:none;background:none;}
.tab.active{background:var(--long);color:#fff;font-weight:600;}

/* ── Panels ── */
.panel{display:none;}
.panel.active{display:block;}

/* ── Controls ── */
.ctrl-row{display:flex;gap:8px;align-items:center;margin-bottom:16px;flex-wrap:wrap;}
.sym-select,.tf-select{padding:9px 14px;background:var(--card);border:1px solid var(--border);border-radius:var(--r-sm);font-size:13px;color:var(--text);cursor:pointer;outline:none;font-family:'Noto Sans KR',sans-serif;}
.sym-select:focus,.tf-select:focus{border-color:var(--long);}
.btn-refresh{padding:9px 20px;background:var(--long);color:#fff;border:none;border-radius:var(--r-sm);font-size:13px;font-weight:600;cursor:pointer;transition:all .2s;}
.btn-refresh:hover{opacity:.88;}
.btn-refresh:disabled{opacity:.4;cursor:not-allowed;}
.ws-status{display:inline-flex;align-items:center;gap:6px;font-size:12px;color:var(--text2);margin-left:auto;}
.ws-dot{width:6px;height:6px;border-radius:50%;background:var(--text3);}
.ws-dot.live{background:var(--long);animation:pulse 1.5s ease-in-out infinite;}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}

/* ── Ticker ── */
.ticker-row{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:16px;}
.ticker-card{background:var(--card);border:1px solid var(--border);border-radius:var(--r);padding:12px 16px;min-width:130px;flex:1;}
.ticker-lbl{font-size:11px;font-weight:500;color:var(--text2);margin-bottom:4px;}
.ticker-val{font-size:18px;font-weight:700;font-family:'IBM Plex Mono',monospace;}
.ticker-val.pos{color:var(--long);}
.ticker-val.neg{color:var(--short);}
.ticker-val.neu{color:var(--text);}

/* ── Chart ── */
#chart-container{width:100%;height:400px;background:var(--card);border:1px solid var(--border);border-radius:var(--r);overflow:hidden;margin-bottom:16px;}

/* ── Signal Hero ── */
.sig-hero{border-radius:var(--r);padding:22px 26px;margin-bottom:10px;border:2px solid;}
.sig-hero-top{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:16px;}
.sig-hero-bottom{display:flex;align-items:center;gap:20px;padding-top:16px;border-top:1px solid rgba(255,255,255,0.08);}
.sig-entry-lbl{font-size:11px;font-weight:500;color:var(--text3);text-transform:uppercase;letter-spacing:.8px;margin-bottom:4px;}
.sig-entry-val{font-size:19px;font-weight:700;font-family:'IBM Plex Mono',monospace;}
.sig-entry-val.long{color:var(--long);}
.sig-entry-val.short{color:var(--short);}
.sig-entry-val.hold{color:var(--hold);}
.sig-conf-wrap{flex:1;}
.sig-conf-lbl{font-size:11px;color:var(--text3);margin-bottom:5px;display:flex;justify-content:space-between;align-items:center;}
.sig-conf-bar{height:6px;background:rgba(255,255,255,0.08);border-radius:4px;overflow:hidden;}
.sig-conf-fill{height:100%;border-radius:4px;transition:width 1s ease;}
.sig-conf-fill.long{background:var(--long);}
.sig-conf-fill.short{background:var(--short);}
.sig-conf-fill.hold{background:var(--hold);}
.sig-hero.long{background:var(--long-bg);border-color:rgba(6,182,107,.4);}
.sig-hero.short{background:var(--short-bg);border-color:rgba(240,68,82,.4);}
.sig-hero.hold{background:var(--hold-bg);border-color:rgba(245,166,35,.4);}
.sig-left{display:flex;align-items:center;gap:16px;}
.sig-badge{font-size:11px;font-weight:700;letter-spacing:1px;padding:3px 10px;border-radius:4px;margin-bottom:6px;display:inline-block;}
.sig-badge.long{background:var(--long);color:#fff;}
.sig-badge.short{background:var(--short);color:#fff;}
.sig-badge.hold{background:var(--hold);color:#fff;}
.sig-name{font-size:28px;font-weight:700;line-height:1;}
.sig-name.long{color:var(--long);}
.sig-name.short{color:var(--short);}
.sig-name.hold{color:var(--hold);}
.sig-reason{font-size:13px;color:var(--text2);margin-top:5px;max-width:500px;line-height:1.5;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.sig-right{text-align:right;flex-shrink:0;}
.sig-lev-lbl{font-size:13px;font-weight:600;color:var(--text2);margin-bottom:4px;}
.sig-lev-val{font-size:26px;font-weight:700;font-family:'IBM Plex Mono',monospace;color:var(--text);}

/* ── 3-col summary ── */
.sum-row{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;margin-bottom:10px;}
.sum-card{background:var(--card);border:1px solid var(--border);border-radius:var(--r);padding:16px 18px;}
.sum-lbl{font-size:11px;font-weight:500;color:var(--text2);margin-bottom:6px;}
.sum-val{font-size:20px;font-weight:700;font-family:'IBM Plex Mono',monospace;}
.sum-val.pos{color:var(--long);}
.sum-val.neg{color:var(--short);}
.sum-val.neu{color:var(--hold);}
.sum-sub{font-size:12px;color:var(--text2);margin-top:4px;}

/* ── Price Cards ── */
.price-row{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;margin-bottom:10px;}
.price-card{background:var(--card);border:1px solid var(--border);border-radius:var(--r);padding:18px;}
.price-tag{font-size:17px;font-weight:700;margin-bottom:8px;}
.price-tag.buy{color:var(--long);}
.price-tag.sell{color:var(--short);}
.price-tag.stop{color:var(--hold);}
.price-val{font-size:13px;font-weight:600;font-family:'IBM Plex Mono',monospace;color:var(--text);margin-bottom:4px;}
.price-note{font-size:12px;color:var(--text2);line-height:1.5;}

/* ── Indicators ── */
.sec-label{font-size:11px;font-weight:600;color:var(--text3);text-transform:uppercase;letter-spacing:1px;margin:16px 0 8px;}
.ind-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-bottom:10px;}
@media(max-width:640px){.ind-grid{grid-template-columns:repeat(2,1fr);}.sum-row,.price-row{grid-template-columns:1fr;}}
.ind-card{background:var(--card);border:1px solid var(--border);border-radius:var(--r);padding:14px 16px;}
.ind-name{font-size:11px;font-weight:500;color:var(--text2);margin-bottom:6px;}
.ind-row{display:flex;align-items:center;gap:7px;}
.ind-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0;}
.ind-dot.bull{background:var(--long);}
.ind-dot.bear{background:var(--short);}
.ind-dot.neu{background:var(--hold);}
.ind-val{font-size:13px;font-weight:600;font-family:'IBM Plex Mono',monospace;}
.ind-val.bull{color:var(--long);}
.ind-val.bear{color:var(--short);}
.ind-val.neu{color:var(--hold);}
.ind-sub{font-size:10px;color:var(--text3);margin-top:3px;}

/* ── Analysis card ── */
.ana-card{background:var(--card);border:1px solid var(--border);border-radius:var(--r);padding:18px 20px;margin-bottom:8px;}
.ana-head{display:flex;align-items:center;gap:8px;font-size:13px;font-weight:600;margin-bottom:12px;padding-bottom:10px;border-bottom:1px solid var(--border);}
.ana-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;}
.ana-body{font-size:13px;color:var(--text2);line-height:1.8;}

/* ── RR block ── */
.rr-card{background:var(--card);border:1px solid var(--border);border-radius:var(--r);padding:14px 18px;margin-bottom:10px;display:flex;align-items:center;gap:20px;}
.rr-item{text-align:center;}
.rr-lbl{font-size:10px;color:var(--text3);text-transform:uppercase;letter-spacing:.5px;margin-bottom:4px;}
.rr-val{font-size:16px;font-weight:700;font-family:'IBM Plex Mono',monospace;}

/* ── Disclaimer ── */
.disclaimer{background:var(--card);border:1px solid var(--border);border-radius:var(--r);padding:12px 16px;font-size:11px;color:var(--text3);line-height:1.6;margin-top:8px;}

/* ── Loading ── */
.loading-state{text-align:center;padding:60px 20px;color:var(--text2);}
.spin{width:32px;height:32px;border:3px solid var(--border);border-top-color:var(--long);border-radius:50%;animation:spin .8s linear infinite;margin:0 auto 16px;}
@keyframes spin{to{transform:rotate(360deg)}}

/* ── Scrollbar ── */
::-webkit-scrollbar{width:4px;}
::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px;}

/* ── 체험판 블러 ── */
.trial-blur{filter:blur(7px);user-select:none;pointer-events:none;transition:filter .3s;}
.trial-lock{position:relative;}
.trial-lock-overlay{
  position:absolute;inset:0;z-index:10;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  background:rgba(13,17,26,0.6);border-radius:var(--r);gap:10px;
}
.trial-lock-icon{font-size:28px;}
.trial-lock-text{font-size:13px;font-weight:600;color:var(--text2);text-align:center;}
.trial-lock-btn{
  padding:9px 22px;background:var(--green);color:#fff;
  border:none;border-radius:8px;font-size:13px;font-weight:700;
  cursor:pointer;margin-top:4px;transition:opacity .2s;
}
.trial-lock-btn:hover{opacity:.88;}
.trial-banner{
  background:rgba(6,182,107,0.07);border:1px solid rgba(6,182,107,0.25);
  border-radius:var(--r);padding:12px 18px;margin-bottom:12px;
  display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;
}
.trial-banner-text{font-size:13px;color:var(--text2);}
.trial-banner-text span{color:var(--green);font-weight:600;}
.trial-banner-btn{
  padding:7px 18px;background:var(--green);color:#fff;
  border:none;border-radius:7px;font-size:12px;font-weight:700;
  cursor:pointer;white-space:nowrap;
}
</style>
</head>
<body>

<!-- License Gate -->
<div class="lg" id="licenseGate">
  <div class="lg-box">
    <div class="lg-logo">₿</div>
    <div class="lg-badge"><div class="lg-dot"></div> BTC Signal AI</div>
    <div class="lg-title">Enter Your License Key</div>
    <div class="lg-sub">Enter the key from your purchase email<br>and get instant access.</div>
    <input class="lg-input" id="lgInput" placeholder="BTCAI-XXXX-XXXX-XX" maxlength="32" autocomplete="off">
    <button class="lg-btn" id="lgBtn" onclick="submitKey()">Confirm Key</button>
    <div class="lg-error" id="lgError"></div>
    <div style="display:flex;align-items:center;gap:10px;margin:16px 0 4px;">
      <div style="flex:1;height:1px;background:var(--border);"></div>
      <span style="font-size:12px;color:var(--text3);">or</span>
      <div style="flex:1;height:1px;background:var(--border);"></div>
    </div>
    <button class="lg-btn" style="background:transparent;border:1px solid var(--border);color:var(--text2);margin-top:0;" onclick="startTrial()">🔍 Try Free Demo</button>
    <div class="lg-info">Your key is saved on this device after first entry.<br>Support: contact your purchase source</div>
  </div>
</div>

<div class="wrap">
  <header>
    <div class="hd-left">
      <div class="logo">₿</div>
      <div>
        <div class="hd-title">BTC Signal AI</div>
        <div class="hd-sub">Real-Time Technical Analysis · Auto Trading Signals</div>
      </div>
    </div>
    <div class="hd-badge">v3.0</div>
  </header>

  <div class="tabs">
    <div class="tab active" onclick="switchTab('signal')">📊 Live Analysis</div>
    <div class="tab" onclick="switchTab('chart')">📈 Chart</div>
  </div>

  <!-- Signal Panel -->
  <div class="panel active" id="panel-signal">
    <div class="ctrl-row">
      <select class="sym-select" id="symSelect" onchange="onSymbolChange()">
        <option value="BTCUSDT">BTC/USDT</option>
        <option value="ETHUSDT">ETH/USDT</option>
        <option value="SOLUSDT">SOL/USDT</option>
        <option value="BNBUSDT">BNB/USDT</option>
      </select>
      <select class="tf-select" id="tfSelect" onchange="onTfChange()">
        <option value="1m">1m</option>
        <option value="5m">5m</option>
        <option value="15m" selected>15m</option>
        <option value="1h">1h</option>
        <option value="4h">4h</option>
        <option value="1d">1d</option>
      </select>
      <button class="btn-refresh" id="refreshBtn" onclick="runAnalysis()">🔄 Refresh Analysis</button>
      <div class="ws-status"><div class="ws-dot" id="wsDot"></div><span id="wsLbl">Connecting...</span></div>
    </div>

    <div class="ticker-row">
      <div class="ticker-card"><div class="ticker-lbl">Price</div><div class="ticker-val neu mono" id="tkPrice">—</div></div>
      <div class="ticker-card"><div class="ticker-lbl">24h Change</div><div class="ticker-val" id="tkChange">—</div></div>
      <div class="ticker-card"><div class="ticker-lbl">24h High</div><div class="ticker-val pos mono" id="tkHigh">—</div></div>
      <div class="ticker-card"><div class="ticker-lbl">24h Low</div><div class="ticker-val neg mono" id="tkLow">—</div></div>
      <div class="ticker-card"><div class="ticker-lbl">24h Volume</div><div class="ticker-val neu" id="tkVol">—</div></div>
    </div>

    <div id="analysisArea">
      <div class="loading-state" id="loadingState">
        <div class="spin"></div>
        <div>Loading data...</div>
      </div>
    </div>
  </div>

  <!-- Chart Panel -->
  <div class="panel" id="panel-chart">
    <div class="ctrl-row">
      <select class="sym-select" id="chartSymSelect" onchange="onChartSymChange()">
        <option value="BTCUSDT">BTC/USDT</option>
        <option value="ETHUSDT">ETH/USDT</option>
        <option value="SOLUSDT">SOL/USDT</option>
        <option value="BNBUSDT">BNB/USDT</option>
      </select>
      <select class="tf-select" id="chartTfSelect" onchange="onChartTfChange()">
        <option value="1m">1m</option>
        <option value="5m">5m</option>
        <option value="15m" selected>15m</option>
        <option value="1h">1h</option>
        <option value="4h">4h</option>
        <option value="1d">1d</option>
      </select>
      <div class="ws-status"><div class="ws-dot" id="chartWsDot"></div><span id="chartWsLbl">—</span></div>
    </div>
    <div id="chart-container"></div>
  </div>
</div>

<script is:inline>
// ════════════════════════════════════════
// LICENSE (server-side verification)
// ════════════════════════════════════════
const BACKEND_VERIFY_API = '/api/license/verify';
const BACKEND_SESSION_API = '/api/license/session';

window.resetLicense = async () => {
  try {
    await fetch(BACKEND_SESSION_API, {
      method: 'DELETE',
      credentials: 'same-origin'
    });
  } catch (e) {}
  location.reload();
};

function startTrial() {
  isTrial = true;
  document.getElementById('licenseGate').classList.add('hidden');
  init();
}

function showLicenseGate() {
  document.getElementById('licenseGate').classList.remove('hidden');
  document.getElementById('lgInput').focus();
}

function setLgErr(msg) {
  document.getElementById('lgError').textContent = msg || '';
}

async function submitKey() {
  const btn = document.getElementById('lgBtn');
  const key = document.getElementById('lgInput').value.trim().toUpperCase();

  if (!key) {
    setLgErr('Enter Your License Key.');
    return;
  }

  btn.disabled = true;
  btn.textContent = 'Verifying...';
  setLgErr('');

  try {
    const res = await fetch(BACKEND_VERIFY_API, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      credentials: 'same-origin',
      body: JSON.stringify({ key })
    });

    const data = await res.json();

    if (!data.ok) {
      setLgErr(data.msg || 'Verification failed');
      return;
    }

    isTrial = false;
    document.getElementById('licenseGate').classList.add('hidden');
    init();
  } catch (e) {
    setLgErr('Connection failed: ' + e.message);
  } finally {
    btn.disabled = false;
    btn.textContent = 'Confirm Key';
  }
}

document.getElementById('lgInput').addEventListener('input', function() {
  let v = this.value.replace(/-/g,'').toUpperCase();
  if (v.length > 5)  v = v.slice(0,5) + '-' + v.slice(5);
  if (v.length > 10) v = v.slice(0,10) + '-' + v.slice(10);
  if (v.length > 15) v = v.slice(0,15) + '-' + v.slice(15);
  this.value = v.slice(0,20);
});
document.getElementById('lgInput').addEventListener('keydown', e => {
  if (e.key === 'Enter') submitKey();
});

(async function autoAuth() {
  if (new URLSearchParams(window.location.search).get('trial') === '1') {
    isTrial = true;
    document.getElementById('licenseGate').classList.add('hidden');
    init();
    return;
  }

  try {
    const res = await fetch(BACKEND_SESSION_API, {
      method: 'GET',
      credentials: 'same-origin',
      cache: 'no-store'
    });

    const data = await res.json();

    if (data.ok) {
      isTrial = false;
      document.getElementById('licenseGate').classList.add('hidden');
      init();
    }
  } catch (e) {
    // keep gate open
  }
})();

// ════════════════════════════════════════
// TAB
// ════════════════════════════════════════
function switchTab(id) {
  document.querySelectorAll('.tab').forEach((t,i)=>t.classList.toggle('active',i===(id==='signal'?0:1)));
  document.querySelectorAll('.panel').forEach(p=>p.classList.remove('active'));
  document.getElementById('panel-'+id).classList.add('active');
  if (id==='chart') {
    // 신호 탭과 심볼/TF 동기화
    chartSymbol = symbol;
    chartTf = tf;
    document.getElementById('chartSymSelect').value = chartSymbol;
    document.getElementById('chartTfSelect').value = chartTf;
    initChart();
  }
}

// ════════════════════════════════════════
// STATE
// ════════════════════════════════════════
let symbol = 'BTCUSDT', tf = '15m';
let isTrial = false;
let ws = null, tickerWs = null;
